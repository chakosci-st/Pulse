  <title>Pulse User Acceptance Test Scenarios</title>
  <style>
    :root{
      --st-blue:#03234b;
      --st-light-blue:#0f6cbd;
      --st-teal:#00a3ad;
      --st-gray:#e9eef4;
      --st-mid-gray:#c7d1db;
      --text:#1f2933;
      --border:#7a8a99;
      --white:#ffffff;
    }

    @page {
      size: A4;
      margin: 18mm 14mm 18mm 14mm;
    }

    * { box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Calibri, "Segoe UI", Arial, Helvetica, sans-serif;
      color: var(--text);
      margin: 0;
      background: #f6f8fb;
      line-height: 1.5;
      font-size: 11pt;
    }

    .document {
      max-width: 1100px;
      margin: 0 auto;
      background: var(--white);
      padding: 32px 40px 60px 40px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }

    h1, h2, h3, h4, h5 {
      color: var(--st-blue);
      margin-top: 22px;
      margin-bottom: 10px;
    }

    h1 {
      font-size: 24pt;
      text-align: center;
      margin-top: 0;
      margin-bottom: 14px;
    }

    h2 {
      font-size: 16pt;
      border-bottom: 2px solid var(--st-blue);
      padding-bottom: 6px;
    }

    h3 {
      font-size: 13pt;
      padding-left: 8px;
      border-left: 4px solid var(--st-teal);
    }

    h4 {
      font-size: 12pt;
      background: var(--st-gray);
      padding: 8px 10px;
      border-left: 4px solid var(--st-light-blue);
    }

    h5 {
      font-size: 11pt;
    }

    p {
      margin: 8px 0;
    }

    .cover {
      min-height: 90vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      text-align: center;
      page-break-after: always;
      break-after: page;
    }

    .cover .brand {
      font-size: 34px;
      font-weight: bold;
      color: var(--st-blue);
      letter-spacing: 1px;
    }

    .cover .subtitle {
      font-size: 26px;
      color: var(--st-light-blue);
      margin-top: 10px;
      font-weight: bold;
    }

    .cover .meta {
      margin-top: 26px;
      font-size: 14px;
    }

    .cover .sign {
      margin-top: 28px;
      line-height: 2;
    }

    .page-break {
      page-break-before: always;
      break-before: page;
      margin-top: 24px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 10px 0 16px 0;
      table-layout: auto;
      font-size: 10.5pt;
    }

    th, td {
      border: 1px solid var(--border);
      padding: 8px 10px;
      vertical-align: top;
      word-break: break-word;
      overflow-wrap: anywhere;
    }

    th {
      background: var(--st-blue);
      color: var(--white);
      text-align: left;
      font-weight: 700;
      white-space: nowrap;
    }

    tr:nth-child(even) td {
      background: #fbfdff;
    }

    td:first-child {
      font-weight: 600;
      background: #f5f8fc;
      width: 28%;
    }

    .toc {
      background: #f8fbff;
      border: 1px solid var(--st-mid-gray);
      padding: 14px 16px;
      margin-bottom: 24px;
    }

    .toc ul {
      list-style: none;
      padding-left: 0;
      margin: 6px 0;
    }

    .toc ul ul {
      padding-left: 18px;
      margin-top: 4px;
    }

    .toc li {
      margin: 4px 0;
    }

    .toc a {
      text-decoration: none;
      color: var(--st-light-blue);
    }

    .toc a:hover {
      text-decoration: underline;
    }

    ul, ol {
      margin-top: 6px;
      margin-bottom: 10px;
      padding-left: 22px;
    }

    .small {
      font-size: 10pt;
      color: #4a5a6a;
    }

    .back-top {
      margin: 6px 0 16px 0;
      font-size: 10pt;
    }

    .back-top a {
      color: var(--st-light-blue);
      text-decoration: none;
    }

    .back-top a:hover {
      text-decoration: underline;
    }

    .section-banner {
      background: linear-gradient(90deg, var(--st-blue), var(--st-light-blue));
      color: var(--white);
      padding: 10px 12px;
      margin-top: 24px;
      margin-bottom: 12px;
      font-size: 18px;
      font-weight: bold;
    }

    .print-note {
      background: #eef7ff;
      border-left: 4px solid var(--st-light-blue);
      padding: 10px 12px;
      margin: 12px 0 18px 0;
    }

    @media print {
      body {
        background: #fff;
        font-size: 10.5pt;
      }
      .document {
        box-shadow: none;
        max-width: none;
        margin: 0;
        padding: 0;
      }
      table {
        page-break-inside: auto;
      }
      tr {
        page-break-inside: avoid;
        page-break-after: auto;
      }
      th {
        position: static;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      .toc a::after {
        content: "";
      }
    }
  </style>
</head>
