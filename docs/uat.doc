  <div class="section-banner" id="sec-10-15">10.15 Negative and Access Control Scenarios</div>

  <h4 id="UAT-ACCESS-001">10.15.1 UAT-ACCESS-001 - Missing Menu For Unauthorized User</h4>
  <table>
    <tr><th>Field</th><th>Detail</th></tr>
    <tr><td>Test Case ID</td><td>UAT-ACCESS-001</td></tr>
    <tr><td>Module</td><td>Access Control</td></tr>
    <tr><td>Test Scenario</td><td>Missing Menu For Unauthorized User</td></tr>
    <tr><td>Objective</td><td>Verify that users without access do not see restricted menus</td></tr>
    <tr><td>Primary Role</td><td>Any restricted user</td></tr>
    <tr><td>Priority</td><td>High</td></tr>
    <tr><td>Preconditions</td><td>User lacks access to at least one controlled module</td></tr>
  </table>
  <table>
    <tr><th>Step No.</th><th>Test Step</th><th>Expected Result</th></tr>
    <tr><td>1</td><td>Log in as restricted user</td><td>Login succeeds</td></tr>
    <tr><td>2</td><td>Check navigation for Templates</td><td>Restricted menu hidden or disabled</td></tr>
    <tr><td>3</td><td>Attempt direct navigation to restricted page if safe</td><td>Access denied</td></tr>
    <tr><td>4</td><td>Repeat for Reports, Admin, or Project Configuration if relevant</td><td>Restrictions consistently enforced</td></tr>
  </table>
  <table>
    <tr><th>Execution Field</th><th>Value</th></tr>
    <tr><td>Tester</td><td></td></tr>
    <tr><td>Execution Date</td><td></td></tr>
    <tr><td>Result</td><td></td></tr>
    <tr><td>Defect ID</td><td></td></tr>
    <tr><td>Evidence Reference</td><td></td></tr>
    <tr><td>Comments</td><td></td></tr>
  </table>

  <h4 id="UAT-ACCESS-002">10.15.2 UAT-ACCESS-002 - Unauthorized User Cannot Delete Project</h4>
  <table>
    <tr><th>Field</th><th>Detail</th></tr>
    <tr><td>Test Case ID</td><td>UAT-ACCESS-002</td></tr>
    <tr><td>Module</td><td>Access Control</td></tr>
    <tr><td>Test Scenario</td><td>Unauthorized User Cannot Delete Project</td></tr>
    <tr><td>Objective</td><td>Verify that project deletion is limited to authorized roles</td></tr>
    <tr><td>Primary Role</td><td>Restricted project member or viewer</td></tr>
    <tr><td>Priority</td><td>High</td></tr>
    <tr><td>Preconditions</td><td>User can view a project but should not delete it</td></tr>
  </table>
  <table>
    <tr><th>Step No.</th><th>Test Step</th><th>Expected Result</th></tr>
    <tr><td>1</td><td>Log in as restricted user</td><td>Login succeeds</td></tr>
    <tr><td>2</td><td>Open visible project</td><td>Project opens</td></tr>
    <tr><td>3</td><td>Open project actions or configuration if visible</td><td>Restricted actions hidden or blocked</td></tr>
    <tr><td>4</td><td>Look for delete action</td><td>Delete unavailable or disabled</td></tr>
    <tr><td>5</td><td>Attempt delete only if safe and visible</td><td>System blocks action</td></tr>
  </table>
  <table>
    <tr><th>Execution Field</th><th>Value</th></tr>
    <tr><td>Tester</td><td></td></tr>
    <tr><td>Execution Date</td><td></td></tr>
    <tr><td>Result</td><td></td></tr>
    <tr><td>Defect ID</td><td></td></tr>
    <tr><td>Evidence Reference</td><td></td></tr>
    <tr><td>Comments</td><td></td></tr>
  </table>

  <h4 id="UAT-ACCESS-003">10.15.3 UAT-ACCESS-003 - Unauthorized User Cannot Modify Templates</h4>
  <table>
    <tr><th>Field</th><th>Detail</th></tr>
    <tr><td>Test Case ID</td><td>UAT-ACCESS-003</td></tr>
    <tr><td>Module</td><td>Access Control</td></tr>
    <tr><td>Test Scenario</td><td>Unauthorized User Cannot Modify Templates</td></tr>
    <tr><td>Objective</td><td>Verify that template maintenance is restricted</td></tr>
    <tr><td>Primary Role</td><td>Daily User or Project Member</td></tr>
    <tr><td>Priority</td><td>High</td></tr>
    <tr><td>Preconditions</td><td>User lacks template manager role</td></tr>
  </table>
  <table>
    <tr><th>Step No.</th><th>Test Step</th><th>Expected Result</th></tr>
    <tr><td>1</td><td>Log in as daily user</td><td>Login succeeds</td></tr>
    <tr><td>2</td><td>Attempt to open Templates</td><td>Access denied or hidden</td></tr>
    <tr><td>3</td><td>Attempt to add or update template records if visible</td><td>Changes blocked</td></tr>
  </table>
