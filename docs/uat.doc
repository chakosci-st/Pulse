    <tr><td>Objective</td><td>Verify that project visibility respects plant, membership, or role scope</td></tr>
    <tr><td>Primary Role</td><td>Daily User, Viewer, Project Member</td></tr>
    <tr><td>Priority</td><td>High</td></tr>
    <tr><td>Preconditions</td><td>Projects exist inside and outside user scope</td></tr>
  </table>
  <table>
