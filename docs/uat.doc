    <tr><td>Defect ID</td><td></td></tr>
    <tr><td>Evidence Reference</td><td></td></tr>
    <tr><td>Comments</td><td></td></tr>
  </table>

  <h4 id="UAT-PROJ-003">10.1.3 UAT-PROJ-003 - Project Review - Add ADHOC Task Using My Tasks</h4>
  <table>
    <tr><th>Field</th><th>Detail</th></tr>
    <tr><td>Test Case ID</td><td>UAT-PROJ-003</td></tr>
    <tr><td>Module</td><td>Projects</td></tr>
    <tr><td>Test Scenario</td><td>Project Review - Add ADHOC Task Using My Tasks</td></tr>
    <tr><td>Objective</td><td>Verify that a user can add an unplanned ADHOC task from My Tasks in Project Review</td></tr>
    <tr><td>Primary Role</td><td>Project Owner or Project Member</td></tr>
    <tr><td>Priority</td><td>High</td></tr>
    <tr><td>Preconditions</td><td>Active project exists. User has permission to add tasks</td></tr>
  </table>
  <table>
    <tr><th>Step No.</th><th>Test Step</th><th>Expected Result</th></tr>
    <tr><td>1</td><td>Open Projects</td><td>Project list opens</td></tr>
