
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Reports";
    ViewBag.TitleIcon = "bi bi-bar-chart-line-fill";
    ViewBag.SubTitle = "Analyze product group coverage, division alignment, and reporting patterns across related product families.";
    ViewBag.ContentHeaderChips = new[] { "Mid-level portfolio grouping", "Division alignment", "Shared product families" };
    ViewBag.ContentHeaderAsideLabel = "Group insight";
    ViewBag.ContentHeaderAsideTitle = "See how mid-level product families are distributed within the division structure.";
    ViewBag.ContentHeaderAsideBody = "Product group reporting helps confirm that related products are being organized consistently and meaningfully.";
    ViewBag.IsActiveTemplatesProductGroups = "menu-open";
    ViewBag.IsActiveTemplatesProductGroupsReports = "active";
    ViewBag.SelectedMenu = "Templates";
    ViewBag.IsActiveTemplates = "active";
}



<div id="productgroupList" class="row">
    <!--begin::Col-->
    <div id="containerAdd" class="col-lg-4 col-md-6 col-12">
        <button id="btnAdd" type="button"
                class="btn btn-default w-100"
                style="height: 100%;">
            <h1><i class="bi bi-plus-circle-fill" style="font-size:80pt"></i></h1>
            <h5>Add new product group</h5>
        </button>
    </div>
    <!--end::Col-->
</div>


@section scripts{

    <script src="~/Areas/Templates/Scripts/productgroups/reports.js"></script>
    <script>
        $(document).ready(function () {
            $('#btnAdd').on('click', function (e) {
                window.location.href = "@Url.Action("New", "ProductGroups", new { area = "Templates" })";
            });
        });
    </script>
}








