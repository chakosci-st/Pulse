
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Reports";
    ViewBag.TitleIcon = "bi bi-bar-chart-line-fill";
    ViewBag.SubTitle = "Analyze division coverage, portfolio distribution, and reporting alignment across major business areas.";
    ViewBag.ContentHeaderChips = new[] { "Top-level portfolio structure", "Technology or market area", "Division governance" };
    ViewBag.ContentHeaderAsideLabel = "Division insight";
    ViewBag.ContentHeaderAsideTitle = "See how the top-level portfolio structure is distributed across the business.";
    ViewBag.ContentHeaderAsideBody = "Division reporting helps verify that major technology and market areas are clearly defined and consistently used.";
    ViewBag.IsActiveTemplatesProductDivisions = "menu-open";
    ViewBag.IsActiveTemplatesProductDivisionsReports = "active";
    ViewBag.SelectedMenu = "Templates";
    ViewBag.IsActiveTemplates = "active";
}



<div id="productdivisionList" class="row">



    <!--begin::Col-->
    <div id="containerAdd" class="col-lg-4 col-md-6 col-12">
        <button id="btnAdd" type="button"
                class="btn btn-default w-100"
                style="height: 100%;">
            <h1><i class="bi bi-plus-circle-fill" style="font-size:80pt"></i></h1>
            <h5>Add new product division</h5>
        </button>
    </div>
    <!--end::Col-->
</div>


@section scripts{

    <script src="~/Areas/Templates/Scripts/productdivisions/reports.js"></script>
    <script>
        $(document).ready(function () {
            $('#btnAdd').on('click', function (e) {
                window.location.href = "@Url.Action("New", "ProductDivisions", new { area = "Templates" })";
            });
        });

    </script>
}








