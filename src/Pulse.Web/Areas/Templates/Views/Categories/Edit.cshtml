
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Edit Category";
    ViewBag.TitleIcon = "bi bi-pencil-square";
    ViewBag.SubTitle = "Update how this category classifies projects across the portfolio.";
    ViewBag.ContentHeaderChips = new[] { "Project classification", "Portfolio grouping", "Reporting consistency" };
    ViewBag.ContentHeaderAsideLabel = "Category maintenance";
    ViewBag.ContentHeaderAsideTitle = "Keep project classification rules clear, current, and useful for reporting.";
    ViewBag.ContentHeaderAsideBody = "Adjust the category definition when the portfolio structure changes or a clearer grouping is needed.";
    ViewBag.IsActiveTemplatesCategories = "menu-open";
    ViewBag.IsActiveTemplatesCategoriesAll = "active";
    ViewBag.SelectedMenu = "Templates";
    ViewBag.IsActiveTemplates = "active";
}

<form id="categoryForm" class="needs-validation" novalidate="">
    @Html.Hidden("TransactionKey")
    
    <!--begin::Row-->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-lg">
                <div class="card-body">
                    <h5 class=" mb-3">
                        Update Category
                        <br />
                        <small style="font-size:12pt; font-weight:normal">Update existing category</small>
                    </h5>
                    <div class="form-group mb-3">
                        <label for="Code" class="form-label">Category Code<span class="required-indicator sr-only"></span></label>
                        <div class="input-group has-validation">
                            <input type="text" class="form-control" id="Code" name="Code" required="" readonly>
                        </div>
                    </div>
                    <div class="form-group mb-3">
                        <label for="Name" class="form-label">Category Name<span class="required-indicator sr-only"> (required)</span></label>
                        <div class="input-group has-validation">
                            <input type="text" class="form-control" id="Name" name="Name" placeholder="Enter Category Name" required="">
                            <div class="invalid-feedback">Please provide a category name.</div>
                        </div>
                    </div>
                    <div class="form-group mb-3">
                        <label for="Name" class="form-label">Category Description</label>
                        <div class="input-group has-validation">
                            <input type="text" class="form-control" id="Description" name="Description" placeholder="Enter Category Description">

                        </div>
                    </div>
                    <div class="form-group my-3">
                        <div id="isActive"></div>
                    </div>
                </div>
                <!-- /.card-body -->
                <div class="card-footer clearfix">
                    <div class="  m-0 float-end">
                        <a href="@Url.Action("Index", "Categories", new { area = "Templates" })" class="btn btn-default">Cancel</a> <button class="btn btn-success" type="submit">Save</button>
                    </div>
                </div>
                <!-- /.card-footer -->
            </div>
        </div>
        <!-- /.col -->
    </div>
    <!--end::Row-->
</form>


@section scripts{
    <script src="~/node_modules/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/Scripts/locals/switch-button.js"></script>
    <script>
        var id = '@ViewBag.Id';
    </script>
    <script src="~/Areas/Templates/Scripts/categories/edit.js"></script>
}