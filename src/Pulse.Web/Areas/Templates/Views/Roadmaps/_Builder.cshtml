<style>
    .milestone-card {
        border-left: 6px solid #0d6efd;
        background: #fff;
        margin-bottom: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        position: relative;
    }

    .milestone-header {
        cursor: pointer;
    }

    .milestone-header-title {
        padding-left: 40px;
        position: absolute
    }

    .attachments-container .attachment.sortable-ghost {
        background-color: var(--bs-secondary-bg, #e2e3e5) !important;
    }

    .activity-card {
        margin-left: 2rem;
        background: #f8f9fa;
        border-left: 4px solid #0dcaf0;
        margin-bottom: 1rem;
        position: relative;
    }

    .chip {
        display: inline-block;
        padding: 0.25em 0.75em;
        border-radius: 1em;
        background: #e9ecef;
        margin-right: 0.5em;
        font-size: 0.9em;
    }

    .attachment {
        display: inline-block;
        margin-right: 0.5em;
        color: #0d6efd;
    }

    .fab {
        position: fixed;
        right: 2rem;
        bottom: 2rem;
        z-index: 1000;
        background: #0d6efd;
        color: #fff;
        border-radius: 50%;
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        cursor: pointer;
    }

    .milestone-actions, .activity-actions {
        display: flex;
        gap: 0.5em;
    }

    .collapse-chevron {
        font-size: 1.2em;
        margin-right: 0.5em;
        color: #0d6efd;
        vertical-align: middle;
    }

    .collapsed .milestone-body, .collapsed .activity-body {
        display: none;
    }

    .milestone-body, .activity-body {
        margin-top: 1em;
    }

    .import-export-bar {
        display: flex;
        justify-content: flex-end;
        gap: 0.5em;
        margin-bottom: 1em;
    }

    @@media (max-width: 600px) {
        .activity-card {
            margin-left: 0.5rem;
        }
    }
</style>
<h5 class="fw-semibold mb-3">Milestones, Activities and Forms</h5>
<div class="mb-3">
    <button class="btn btn-primary btn-sm" mb-3" id="addRootMilestoneBtn">+ Add Milestone</button>
    <button class="btn btn-info btn-sm" mb-3" id="addRootActivityBtn">+ Add Root Activity</button>
    <button class="btn btn-secondary btn-sm" mb-3" id="addRootFormBtn"><i class="bi bi-file-earmark-plus"></i> Add Root Form</button>
    <button class="btn btn-outline-secondary btn-sm" id="importBtn"><i class="bi bi-upload"></i> Import</button>
    <input type="file" id="importFile" accept=".json" style="display:none">
    <button class="btn btn-outline-secondary btn-sm" id="exportBtn"><i class="bi bi-download"></i> Export</button>
</div>


<div id="timeline">
    <div class="roadmap-card p-4" data-key="roadmap">
    </div>
</div>

<div class="fab" id="fabAddMilestone" title="Add Milestone">
    <i class="bi bi-plus"></i>
</div>

<!-- Modal for Add/Edit Node -->
<div class="modal fade" id="nodeModal" tabindex="-1">
    <div class="modal-dialog">
        <form class="modal-content" id="nodeForm">
            <div class="modal-header">
                <h5 class="modal-title" id="nodeModalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="nodeModalBody"></div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary" id="nodeModalSaveBtn">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal for Add Form -->
<div class="modal fade" id="formModal" tabindex="-1">
    <div class="modal-dialog">
        <form class="modal-content" id="formForm">
            <div class="modal-header">
                <h5 class="modal-title" id="formModalTitle">Add Form</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="formModalBody">
                <div class="form-floating mb-2">
                    <select class="form-select" id="modalForms" required></select>
                    <label for="modalForms">Form</label>
                </div>
                <div class="form-floating mb-2">
                    <textarea class="form-control" id="modalDescription" disabled></textarea>
                    <label for="modalDescription">Description</label>
                </div>
                <hr />
                <h6>Preview</h6>
                <div id="containerPreview"></div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary" id="formModalSaveBtn">Add</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </form>
    </div>
</div>


