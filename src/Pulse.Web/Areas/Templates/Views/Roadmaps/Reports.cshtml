
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Reports";
    ViewBag.TitleIcon = "bi bi-bar-chart-line-fill";
    ViewBag.SubTitle = "Analyze roadmap usage, assignment coverage, and reusable delivery patterns across projects.";
    ViewBag.ContentHeaderChips = new[] { "Reusable project templates", "Task sequence planning", "Project assignment ready" };
    ViewBag.ContentHeaderAsideLabel = "Roadmap insight";
    ViewBag.ContentHeaderAsideTitle = "See how reusable project templates are being assigned and reused across the portfolio.";
    ViewBag.ContentHeaderAsideBody = "Roadmap reporting helps reveal which delivery patterns are active, effective, and ready for broader reuse.";
    ViewBag.IsActiveTemplatesRoadmaps = "menu-open";
    ViewBag.IsActiveTemplatesRoadmapsReports = "active";
    ViewBag.SelectedMenu = "Templates";
    ViewBag.IsActiveTemplates = "active";
}



<div id="productdivisionList" class="row">



    <!--begin::Col-->
    <div id="containerAdd" class="col-lg-4 col-md-6 col-12">
        <button id="btnAdd" type="button"
                class="btn btn-default w-100"
                style="height: 100%;">
            <h1><i class="bi bi-plus-circle-fill" style="font-size:80pt"></i></h1>
            <h5>Add new product division</h5>
        </button>
    </div>
    <!--end::Col-->
</div>


@section scripts{

    <script src="~/Areas/Templates/Scripts/productdivisions/reports.js"></script>
    <script>
        $(document).ready(function () {
            $('#btnAdd').on('click', function (e) {
                window.location.href = "@Url.Action("New", "ProductDivisions", new { area = "Templates" })";
            });
        });

    </script>
}








