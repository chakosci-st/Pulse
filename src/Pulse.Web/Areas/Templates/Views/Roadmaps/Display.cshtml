@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Display Roadmap";
    ViewBag.TitleIcon = "bi bi-eye-fill";
    ViewBag.SubTitle = "Review this reusable roadmap template and the project structure it defines.";
    ViewBag.ContentHeaderChips = new[] { "Reusable project templates", "Task sequence planning", "Project assignment ready" };
    ViewBag.ContentHeaderAsideLabel = "Roadmap review";
    ViewBag.ContentHeaderAsideTitle = "Inspect the reusable sequence before assigning it to more projects.";
    ViewBag.ContentHeaderAsideBody = "This view keeps the roadmap intent visible so teams understand what structure a project will inherit.";
    ViewBag.IsActiveTemplatesRoadmaps = "menu-open";
    ViewBag.IsActiveTemplatesRoadmapsAll = "active";
    ViewBag.SelectedMenu = "Templates";
    ViewBag.IsActiveTemplates = "active";
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-lg h-100">
            <div class="card-body">
                <h5 class="mb-3">Roadmap Summary</h5>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label text-muted">Roadmap ID</label>
                        <div id="roadmapSysId" class="form-control bg-light">-</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted">Status</label>
                        <div id="roadmapStatus" class="form-control bg-light d-flex align-items-center">-</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted">Roadmap Name</label>
                        <div id="roadmapName" class="form-control bg-light">-</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted">Description</label>
                        <div id="roadmapDescription" class="form-control bg-light">-</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted">Category</label>
                        <div id="roadmapCategory" class="form-control bg-light">-</div>
                    </div>
                </div>
            </div>
            <div class="card-footer clearfix">
                <div class="m-0 float-end">
                    <a href="@Url.Action("Index", "Roadmaps", new { area = "Templates" })" class="btn btn-default">Back to list</a>
                    <a href="@Url.Action("Edit", "Roadmaps", new { area = "Templates", code = ViewBag.Id })" class="btn btn-primary">Edit</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card shadow-lg">
            <div class="card-body">
                <h5 class="mb-3">Roadmap Structure Preview</h5>
                <pre id="roadmapStructurePreview" class="bg-light border rounded-3 p-3 mb-0" style="max-height: 520px; overflow: auto; white-space: pre-wrap; word-break: break-word;">{}</pre>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script>
        var id = '@ViewBag.Id';
    </script>
    <script src="~/Areas/Templates/Scripts/roadmaps/display.js"></script>
}