    <script>
        //selected
        //switchInput.checked = true;

// Initialize on page load


        var id = '@ViewBag.Id';

        function setStickyMenuWidth() {
            const menu = document.querySelector('.configurable--sticky');
            const col = document.querySelector('.col-lg-3');
            if (menu && col) {
                menu.style.width = col.offsetWidth - 20 + 'px';
            }
        }

        // Set on load and on resize
        window.addEventListener('DOMContentLoaded', setStickyMenuWidth);
        window.addEventListener('resize', setStickyMenuWidth);




        @*// Function to load tab content via AJAX
        function loadTabContent(tabId, url) {
            var $tabPane = $(tabId);
            if ($tabPane.data('loaded')) return; // Prevent reloading

            $.get(url, function (data) {
                $tabPane.html(data);
                $tabPane.data('loaded', true);
            });
        }

