@using Pulse.Web.Helpers

<div class="fab-container">
    <!-- Menu items -->
    <div id="fabMenu" class="fab-menu">
        <div class="fab-item" onclick="openModal('chatModal')">
            <span class="fab-label">Chat</span>
            <button class="fab-mini-btn">
                <i class="bi bi-chat-left-text"></i>
            </button>
        </div>
    </div>

    <button id="mainFab" class="floating-fab">
        <i id="mainFabIcon" class="bi bi-three-dots-vertical"></i>
    </button>
</div>