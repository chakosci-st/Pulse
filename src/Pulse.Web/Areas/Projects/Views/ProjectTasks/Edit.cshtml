
@{
    ViewBag.Title = "Edit Task";
    ViewBag.TitleIcon = "bi bi-pencil-square";
    ViewBag.SubTitle = "Update the task definition, delivery target, ownership context, status, attachments, and working notes in one place.";
    ViewBag.ContentHeaderChips = new[] { "Task maintenance", "Status and target updates", "Attachments and comments" };
    ViewBag.ContentHeaderAsideLabel = "Task control";
    ViewBag.ContentHeaderAsideTitle = "Keep the execution record accurate before the task moves to its next delivery state.";
    ViewBag.ContentHeaderAsideBody = "Use this view to refine the task scope, confirm the target details, and keep supporting files and comments aligned to the actual work in progress.";
    ViewBag.IsActiveTasks = "active";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles{
    <!-- Summernote -->
    <link href="~/node_modules/summernote/dist/summernote-bs5.min.css" rel="stylesheet" />

    <link href="~/Content/locals/stacked-userprofiles.css" rel="stylesheet" />

    <link href="~/node_modules/dropzone/dist/min/dropzone.min.css" rel="stylesheet" />

    <style>

        .layout {
            display: grid;
            grid-template-columns: minmax(0, 2fr) minmax(260px, 1fr);
            gap: 20px;
        }


        .card-local {
            background: #ffffff;
            border-radius: 16px;
            padding: 20px 22px;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
            margin-bottom: 10px;
        }

        .task-header {
            margin-bottom: 16px;
        }

        .task-title-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 8px;
        }

            .task-title-row h1 {
                font-size: 20px;
                font-weight: 600;
                color: #111827;
            }

        /* Chips */
        .chips {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .chip {
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        /* Priority */
        .chip-priority-high {
            background: #fef3c7;
            color: #92400e;
        }

        .chip-priority-medium {
            background: #e0f2fe;
            color: #075985;
        }

        .chip-priority-low {
            background: #dcfce7;
            color: #166534;
        }



        /* Status */
        .chip-status-todo {
            background: #e5edff;
            color: #4338ca;
        }

        .chip-status-inprogress {
            background: #fee2e2;
            color: #b91c1c;
        }

        .chip-status-done {
            background: #e5f9f0;
            color: #0f766e;
        }


        .task-subtitle {
            font-size: 14px;
            color: #6b7280;
        }

        .section-title {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 8px;
        }

        .section-body {
            font-size: 14px;
            color: #9ca3af;
        }

        /* dataentry row */
        .dataentry-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .save-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            border: 1px solid #e5e7eb;
            padding: 6px 12px;
            background: #ffffff;
            font-size: 13px;
            cursor: pointer;
            color: #374151;
        }



        /* Attachments row */
        .inline-dropzone {
            border: 2px dashed #94a3b8;
            border-radius: 1rem;
            background: #f8fafc;
            padding: 0.75rem;
            min-height: 120px;
            margin-bottom: 0.85rem;
        }

        .attachments-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .attachment-list {
            margin-top: 4px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .attachment-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 10px;
            border-radius: 10px;
            border: 1px solid #e5e7eb;
            background: #f9fafb;
            font-size: 13px;
        }

        .attachment-main {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .attachment-icon {
            width: 26px;
            height: 26px;
            border-radius: 6px;
            background: #e5edff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #4338ca;
            font-size: 14px;
        }

        .attachment-name {
            font-weight: 500;
            color: #111827;
        }

        .attachment-meta {
            font-size: 11px;
            color: #9ca3af;
        }

        .attachment-actions {
            display: flex;
            gap: 6px;
            align-items: center;
            font-size: 11px;
            color: #6366f1;
            cursor: pointer;
        }



            .attachment-actions span {
                padding: 4px 6px;
                border-radius: 999px;
                transition: background 0.15s;
            }

                .attachment-actions span:hover {
                    background: #e0e7ff;
                }

        .action-link {
            text-decoration: none !important;
        }
        /* Comments */
        .comments-count {
            font-size: 13px;
            color: #9ca3af;
            margin-bottom: 12px;
        }

        .comment-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 14px;
        }

        .comment-item {
            display: flex;
            gap: 10px;
            font-size: 13px;
        }

        .avatar {
            width: 28px;
            height: 28px;
            border-radius: 999px;
            background: #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            color: #4b5563;
            flex-shrink: 0;
        }

        .comment-body {
            background: #f9fafb;
            border-radius: 12px;
            padding: 8px 10px;
            flex: 1;
        }

        .comment-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 4px;
        }

        .comment-author {
            font-weight: 500;
            color: #111827;
        }

        .comment-time {
            font-size: 11px;
            color: #9ca3af;
        }

        .comment-text {
            font-size: 13px;
            color: #4b5563;
            white-space: pre-wrap;
        }

        .comment-text-rich {
            white-space: normal;
            line-height: 1.45;
        }

            .comment-text-rich p {
                margin-bottom: 0.35rem;
            }

        .comment-mode-pill {
            display: inline-flex;
            gap: 4px;
            padding: 4px;
            border-radius: 999px;
            border: 1px solid #e5e7eb;
            background: #ffffff;
        }

        .comment-mode-pill__btn {
            border: 0;
            border-radius: 999px;
            padding: 4px 10px;
            font-size: 12px;
            color: #6b7280;
            background: transparent;
        }

            .comment-mode-pill__btn.is-active {
                background: #eef2ff;
                color: #3730a3;
                font-weight: 600;
            }

        .comment-entry {
            width: 100%;
        }

        .comment-entry-plain input {
            border: none;
            outline: none;
            width: 100%;
            font-size: 14px;
            background: transparent;
        }

        .comment-entry-rich .note-editor.note-frame {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            background: #ffffff;
        }

        .comment-box {
            display: flex;
            align-items: flex-end;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 4px;
            background: #ffffff;
            border-radius: 14px;
            padding: 8px;
            border: 1px solid #e5e7eb;
        }

            .comment-box .comment-entry {
                flex: 1 1 280px;
            }

        .send-btn {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: none;
            background: #a855f7;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            cursor: pointer;
            font-size: 16px;
        }

        /* Details panel */
        .details-card-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 18px;
        }

        .detail-field {
            margin-bottom: 18px;
        }

        .detail-label {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #9ca3af;
            margin-bottom: 6px;
        }

        .select-like {
            border-radius: 10px;
            border: 1px solid #e5e7eb;
            padding: 10px 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 14px;
            color: #111827;
            background: #ffffff;
        }

            .select-like span.value {
                font-weight: 500;
            }

            .select-like span.caret {
                font-size: 12px;
                color: #9ca3af;
            }

        .detail-date {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: #111827;
            margin-top: 4px;
        }

        .date-icon {
            width: 20px;
            height: 20px;
            border-radius: 999px;
            border: 1px solid #d1d5db;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            color: #6b7280;
        }

        @@media (max-width: 880px) {
            .layout {
                grid-template-columns: 1fr;
            }
        }



        .project-summary {
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .project-main {
            width: 100%;
        }

        .project-title {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: baseline;
            margin-bottom: 6px;
        }

        .project-no {
            font-weight: 600;
            font-size: 15px;
            color: #111827;
            padding: 2px 8px;
            border-radius: 999px;
            background: #e5edff;
            color: #4338ca;
        }

        .project-name {
            font-weight: 500;
            font-size: 15px;
            color: #111827;
        }

        .project-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            font-size: 12px;
            color: #6b7280;
        }

        .meta-item {
            display: flex;
            gap: 4px;
            align-items: center;
        }

        .meta-label {
            text-transform: uppercase;
            letter-spacing: 0.04em;
            font-size: 11px;
            color: #9ca3af;
        }

        .meta-value {
            font-weight: 500;
            color: #111827;
        }
    </style>

}

@section scripts{
    <!-- Dependencies -->
    <script src="~/node_modules/summernote/dist/summernote.js"></script>
    <script src="~/node_modules/summernote/dist/summernote-bs5.min.js"></script>
    <script src="~/node_modules/sortablejs/Sortable.min.js"></script>
    <script src="~/node_modules/dropzone/dist/dropzone-min.js"></script>



    <!-- local-dynamic-fields -->
    <script src="~/Scripts/locals/utils.js"></script>
    <script src="~/Scripts/locals/dynamic-fields.js"></script>


    <script src="~/node_modules/dropzone/dist/min/dropzone.min.js"></script>

    <script src="~/Scripts/locals/stacked-userprofiles.js"></script>


    <!-- local-helpers -->
    <script src="~/Areas/Projects/Scripts/projects/common-functions.js"></script>
    <script src="~/Areas/Projects/Scripts/helpers/projectattachment.js"></script>
    <script src="~/Areas/Projects/Scripts/helpers/projectdata.js"></script>
    <script src="~/Areas/Projects/Scripts/helpers/projectcomments.js"></script>

    <script>
        window.isTaskReadOnlyPage = @((ViewBag.IsTaskReadOnly ?? false).ToString().ToLowerInvariant());
    </script>

    <script src="~/Areas/Projects/Scripts/projecttasks/edit.js"></script>
}

<!-- Top Back bar -->
<div class="page-header">
    <button   class="btn btn-link" style="text-decoration-line:none" onclick="history.back();">
        <span class="arrow">&#8592;</span>
        <span>Back</span>
    </button>
</div>

<input type="hidden" id="ProjectTaskSysId" value="@ViewBag.Id" />
<input type="hidden" id="ProjectNo" />
<input type="hidden" id="RoadmapActivitySysId" />

<div class="layout">
    <!-- Left side -->
    <div class="left-column">
        <!-- Task main info -->
        <div class="card-local task-header">
            <div class="task-title-row">
                <h1 id="task-title">Loading...</h1>
                <div class="chips">
                    @*<span id="chip-priority" class="chip"></span>*@
                    <span id="chip-isrequired" class="chip"></span>
                    <span id="chip-status" class="chip"></span>
                </div>
            </div>
            <p class="task-subtitle" id="task-description">
                <!-- description -->
            </p>
        </div>

        <!-- Attachments -->
        <form id="formUpdateForm">
            <div class="card-local">
                <div class="dataentry-header">
                    <div class="section-title">Data Entry</div>
                    <button id="btnDataEntryUpdate" class="btn btn-outline-secondary small" type="submit">
                        <i class="bi bi-pencil-square"></i>
                        <span>Update</span>
                    </button>
                </div>
                <div class="section-body">
                    No Data entry required
                </div>
            </div>
        </form>
        <!-- Attachments -->
        <div class="card-local">
            <div class="attachments-header">
                <div class="section-title">Attachments</div>
                <button class="btn btn-outline-secondary small upload-btn" id="upload-toggle">
                    <i class="bi bi-paperclip"></i>
                    <span>Upload</span>
                </button>
            </div>

            <form id="upload-dropzone"
                  class="dropzone inline-dropzone"
                  action="/api/tasks/123/attachments">
                <input type="hidden" id="attachmentsContextId" name="contextId">
                <div class="dz-message">Drop files here or click to upload</div>
            </form>

            <div class="attachment-list" id="attachment-list"></div>
        </div>

        <!-- Comments -->
        <div class="card-local">
            <div class="section-title">
                Comments (<span id="comment-count">0</span>)
            </div>
            <div class="comments-count" id="comment-summary"></div>

            <div class="comment-list" id="comment-list"></div>

            <div class="comment-box">
                <div class="comment-mode-pill" role="group" aria-label="Comment input mode">
                    <button type="button" id="comment-mode-plain" class="comment-mode-pill__btn is-active" aria-pressed="true">Text</button>
                    <button type="button" id="comment-mode-rich" class="comment-mode-pill__btn" aria-pressed="false">Rich text</button>
                </div>
                <div id="comment-entry-plain" class="comment-entry comment-entry-plain">
                    <input type="text"
                           id="comment-input"
                           placeholder="Write a comment..." />
                </div>
                <div id="comment-entry-rich" class="comment-entry comment-entry-rich d-none">
                    <textarea id="comment-input-rich"></textarea>
                </div>
                <button class="send-btn" id="comment-send" type="button">&#10148;</button>
            </div>
        </div>
    </div>

    <!-- Right side: Details -->
    <div class="card-local">
        <div class="details-card-title">Details</div>

        <div class="detail-field">
            <div class="detail-label">Status</div>
            <div class="select-like">
                <span class="value" id="detail-status">–</span>
                <span class="caret">&#9662;</span>
            </div>
        </div>



        @*<div class="detail-field">
            <div class="detail-label">Priority</div>
            <div class="select-like">
                <span class="value">High</span>
                <span class="caret">&#9662;</span>
            </div>
        </div>*@

        <div class="detail-field">
            <div class="detail-label">Due Date</div>
            <div class="detail-date">
                <span class="date-icon">&#128340;</span>
                <span id="detail-due-date">Loading...</span>
            </div>
        </div>

        <hr />
        <div class="details-card-title">Project info</div>

        <div class="detail-field">
            <div class="detail-label">Project No</div>
            <div class="select-like">
                <span class="value" id="proj-no-right"></span>
            </div>
        </div>


        <div class="detail-field">
            <div class="detail-label">Project Name</div>
            <div class="select-like">
                <span class="value" id="proj-name-right"></span>
            </div>
        </div>


        <div class="detail-field">
            <div class="detail-label">Project Description</div>
            <div class="select-like">
                <span class="value" id="proj-desc-right"></span>
            </div>
        </div>

        <div class="detail-field">
            <div class="detail-label">Plant Code</div>
            <div class="select-like">
                <span class="value" id="proj-plant-right"></span>
            </div>
        </div>

        <div class="detail-field">
            <div class="detail-label">Category</div>
            <div class="select-like">
                <span class="value" id="proj-category-right"></span>
            </div>
        </div>

        <div class="detail-field">
            <div class="detail-label">Product Division</div>
            <div class="select-like">
                <span class="value" id="proj-division-right"></span>
            </div>
        </div>

        <div class="detail-field">
            <div class="detail-label">Product Group</div>
            <div class="select-like">
                <span class="value" id="proj-prod-group-right"></span>
            </div>
        </div>
    </div> 
</div>