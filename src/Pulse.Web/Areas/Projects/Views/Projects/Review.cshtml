}



<input id="projectNo" type="hidden" value="@ViewBag.ProjectNo" />
<input id="projectName" type="hidden" />
<input id="projectIcon" type="hidden" />
<input id="projectColor" type="hidden" />

<div class="project-workspace-shell">
<section class="project-workspace-hero" aria-label="Project review overview">
    <article class="project-workspace-hero__main">
        <span class="project-workspace-hero__eyebrow"><i class="bi bi-ui-checks-grid"></i>Project Review</span>
        <h1 class="project-workspace-hero__title">
            <span class="project-workspace-hero__icon"><i id="headerIcon" class="bi bi-journal-plus"></i></span>
            <span id="headerTitle">Project Review</span>
        </h1>
        <p class="page-header__subtitle">Review milestone execution, task readiness, ownership, and supporting project context from a single review workspace.</p>
        <div id="chips"></div>
    </article>
    <aside class="project-workspace-hero__side">
        <div id="subcontent"></div>
        <div class="review-mode-toggle" role="group" aria-label="Review mode toggle">
            <button type="button" id="btnReviewModeProject" class="review-mode-toggle__button is-active" data-review-mode="project" aria-pressed="true">
                <i class="fas fa-diagram-project me-1"></i>Project-centric
            </button>
            <button type="button" id="btnReviewModeMember" class="review-mode-toggle__button" data-review-mode="member" aria-pressed="false">
                <i class="fas fa-people-group me-1"></i>Member-centric
            </button>
        </div>
        <div class="project-workspace-hero__note">
            <span class="project-workspace-hero__note-label">Review Mode</span>
            <strong id="reviewModeSummary">Track milestone health, manage task actions, and jump into your assigned work without leaving the page.</strong>
        </div>
    </aside>
</section>

<!-- Main split layout -->
<div class="card layout-main-card">
    <div class="row g-0">

        <!-- Left panel: Milestones -->
        <div class="project-milestones col-md-4 left-panel p-3">
            <div class="project-milestones-header d-flex justify-content-between align-items-center mb-2">
                <div>
                    <div class="milestone-small-label">Milestones</div>
                    <div class="fw-semibold" style="font-size: 0.9rem; color:#111827;">Project phases</div>
                </div>
                <span class="badge bg-indigo-100 text-primary" style="background-color:#e0ecff;color:#1d4ed8;">
                    <i class="fas fa-flag-checkered me-1"></i><span id="active-milestone-count"></span> Active
                </span>
            </div>
            <span id="loading-milestones" class="text-muted" style="font-size:0.8rem;">
                <i class="fas fa-spinner fa-spin me-2"></i>Loading milestones...
            </span>

        </div>

        <!-- Right panel: Activities for selected milestone -->
        <div class="col-md-8 right-panel p-3">

            <div id="projectCentricPanel" class="project-view-panel">

            <!-- Activities Header -->
            <div class="activities-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div>
                    <div class="activities-header-sub">Selected milestone</div>
                    <div class="activities-header-title" id="selectedMilestoneTitle">
                        <i class="fas fa-flag-checkered text-primary"></i>
                        Select Milestone...
                    </div>
                </div>
                <div class="text-end">
                    <div class="activities-header-sub">Milestone progress</div>
                    <div class="fw-semibold" id="selectedMilestoneProgress">0%</div>
                    <button type="button" id="btnToggleActivitiesCollapse" class="btn btn-outline-secondary btn-sm mt-2 me-2">
                        <i class="fas fa-angle-up me-1"></i>Collapse Tasks
                    </button>
                    <button type="button" id="btnReviewManageMyTasks" class="btn btn-outline-dark btn-sm mt-2">
                        <i class="bi bi-card-checklist me-1"></i>My Tasks
                    </button>
                </div>
            </div>

            <!-- Filters -->
            <div class="filter-bar row g-2 align-items-center">
                <div class="col-sm-4 col-12">
                    <div class="filter-label">Status</div>
                    <select id="filterStatus" class="form-select form-select-sm filter-select">
                        <option value="">All statuses</option>
                        <option value="Not Started">Not Started</option>
                        <option value="Ongoing">Ongoing</option>
                        <option value="Completed">Completed</option>
                        <option value="On-Hold">On-Hold</option>
                        <option value="Cancelled">Cancelled</option>
                        <option value="Archived">Archived</option>
                    </select>
                </div>
                <div class="col-sm-4 col-12">
                    <div class="filter-label">Owner</div>
                    <select id="filterOwner" class="form-select form-select-sm filter-select">
                        <option value="">All owners</option>
                    </select>
                </div>
                <div class="col-sm-4 col-12">
                    <div class="filter-label">Search</div>
                    <div class="search-wrapper">
                        <i class="fas fa-search search-icon text-gray-500"></i>
                        <input type="text" id="filterSearch" class="form-control filter-search"
                               placeholder="Activity name...">
                    </div>
                </div>
            </div>
            <div id="loading-tasks" class="text-muted" style="font-size:0.8rem;">
                <i class="fas fa-spinner fa-spin me-2"></i>Loading tasks...
            </div>

            <!-- Activities container -->
