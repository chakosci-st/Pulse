<input type="hidden" id="projectNo"  value="@ViewBag.ProjectNo"  />
<input type="hidden" id="transactionKey" />
<input id="projectName" type="hidden" />
<input id="projectIcon" type="hidden" />
<input id="projectColor" type="hidden" />
<input id="plantCode" type="hidden" />


<div class="row mb-5">
    <div class="col-lg-3">
        <div class="configurable--sticky" style="top: calc(95px + 2rem); width: auto;">
            <div class="card" style="width:100%">
                <ul class="nav flex-column bg-white border-radius-lg p-3">
                    <li class="nav-item">
                        <a class="nav-link text-dark d-flex" data-scroll="" href="#profile">
                            <i class="bi bi-building text-lg me-2"></i>
                            <span class="text-sm">Profile</span>
                        </a>
                    </li>
                    <li class="nav-item pt-2">
                        <a class="nav-link text-dark d-flex" data-scroll="" href="#basic-info">
                            <i class="bi bi-receipt text-lg me-2"></i>
                            <span class="text-sm">Basic Info</span>
                        </a>
                    </li>
                    <li class="nav-item pt-2">
                        <a class="nav-link text-dark d-flex" data-scroll="" href="#product-codes">
                            <i class="bi bi-motherboard text-lg me-2"></i>
                            <span class="text-sm">Product Codes</span>
                        </a>
                    </li>
                    <li class="nav-item pt-2">
                        <a class="nav-link text-dark d-flex" data-scroll="" href="#members">
                            <i class="bi bi-person-vcard text-lg me-2"></i>
                            <span class="text-sm">Members</span>
                        </a>
                    </li>
                    <li class="nav-item pt-2">
                        <a class="nav-link text-dark d-flex" data-scroll="" href="#delete">
                            <i class="bi bi-trash text-lg me-2"></i>
                            <span class="text-sm">Delete Project</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-lg-9 mt-lg-0 mt-4">
        <!-- Card Profile -->
        <div class="card card-body" id="profile">
            <div class="row justify-content-center align-items-center">
                <div class="col-sm-auto col-4">
                    <div class="user-avatar shadow medium site-md">
                        <div class="profile-circle">
                            <i id="iProjectIcon"></i>
                        </div>
                    </div>
                </div>
                <div class="col-sm-auto col-8 my-auto">
                    <div class="h-100">
                        <h5 class="mb-1 font-weight-bolder">
                            <label id="labelProjectName">Project Name</label>
                        </h5>
                        <p class="mb-0 font-weight-normal text-sm">
                            <label id="labelProjectDescription">Project Description</label>
                        </p>
                    </div>
                </div>
                <div class="col-sm-auto ms-sm-auto mt-sm-0 mt-3 d-flex">
                    <div class="d-flex flex-column align-items-sm-end gap-2">
                        <button id="btnRetrieveLatestRoadmap" class="btn btn-outline-primary mb-0" type="button">
                            <i class="bi bi-arrow-repeat me-2"></i>Retrieve latest roadmap structure
                        </button>
                        <small class="text-muted text-sm text-sm-end">
                            Preview and merge new roadmap items without resetting current execution.
                        </small>
                    </div>
                    @*<label class="form-check-label mb-0">
                            <small id="profileVisibility">
                                Switch to active
                            </small>
                        </label>
                        <div class="form-check form-switch ms-2 my-auto">
                            <input class="form-check-input" type="checkbox" id="isActive" checked="">
                        </div>*@
                </div>
            </div>
        </div>
        <!-- Card Basic Info -->
        <div class="card mt-4" id="basic-info">

            <div class="card-body pt-0">
                <div class="py-2">
                    <h5>Basic Info</h5>
                    <p class="section-subtitle">Set the project details and appearance.</p>
                </div>
                <form id="projectForm" class="needs-validation" method="put" novalidate="">

                    <div class="mb-4">

                        <div class="section-subtitle">
                            Set the project name, owner, timeline and define the team members who can own tasks/milestones.
                        </div>
                        <div class="form-floating mb-2">
                            <input type="text" class="form-control" id="projectTitle" name="projectTitle" required placeholder="e.g. New Product Launch">
                            <label class="form-label" for="projectTitle">Project title <span class="text-danger">*</span> (e.g. New Product Launch)</label>
                            <div class="invalid-feedback">Please project name.</div>
                        </div>
                        <div class="form-floating mb-2">
                            <textarea class="form-control" id="projectDescription" rows="5"
                                      placeholder="Short description, main objectives, scope..."></textarea>
                            <label class="form-label ms-2">Project description (Short description, main objectives, scope...)</label>
                        </div>
                        <div class="form-floating mb-2">
                            <select class="form-select" id="productgroupSelect" name="productgroupSelect">
                                <option></option>
                            </select>
                            <label for="productgroupSelect">Product Group <span class="text-danger">*</span></label>
                            <div class="invalid-feedback">Please select a product group.</div>
                        </div>
                        <div class="form-floating mb-2">
                            <select class="form-select" id="productdivisionSelect" name="productdivisionSelect">
                                <option></option>
                            </select>
                            <label for="productdivisionSelect">Product Division <span class="text-danger">*</span></label>
                            <div class="invalid-feedback">Please select a product division.</div>
                        </div>


                        <hr>
                        <div class="section-title">
                            <i class="bi bi-palette2 text-danger"></i>
                            Project appearance
                        </div>
                        <div class="section-subtitle">
                            Choose an icon and highlight color used in dashboards and notifications.
                        </div>
                        <div>
                            <label class="form-label">Project icon</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="hidden" id="icon" />
                                <input type="hidden" id="iconcolor" />
                                <button type="button" class="appearance-pill" id="btnOpenIconPicker">
                                    <span class="border rounded-circle d-inline-flex align-items-center justify-content-center"
                                          style="width:28px;height:28px;">
                                        <i id="projectIconPreview" class="bi bi-rocket-fill"></i>
                                    </span>
                                    <span id="projectIconLabel" class="text-muted small">
                                        bi bi-rocket-fill
                                    </span>
                                </button>
                                <small class="text-muted d-none d-md-inline">
                                    Bootstrap Icons · search in picker
                                </small>
                            </div>
                        </div>
                        <div>
                            <label class="form-label">Primary color</label>
                            <div class="d-flex align-items-center gap-2">
                                <button type="button" class="appearance-pill" id="btnColorPicker">
                                    <span id="projectColorDot"
                                          class="color-dot"
                                          style="background:#3b82f6;"></span>
                                    <span id="projectColorLabel" class="text-muted small">
                                        #3b82f6
                                    </span>
                                </button>
                                <small class="text-muted d-none d-md-inline">
                                    Color picker (Pickr)
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <button class="btn btn-outline-dark m-0 float-end" type="submit">Update basic info</button>

                        </div>
                    </div>
                </form>

            </div>
        </div>
        <!-- Card Product Codes -->
        <div class="card mt-4" id="product-codes">


            <div class="card-body">


                <div class="row">
                    <div class="col-6">
                        <h5>Linked Product Code(s)</h5>
                        <p class="text-sm mb-0">Defined product(s) that is referenced for this project.</p>
                    </div>
                    <div class="col-6">
                        <div class="input-group">
                            <input type="text" id="textProductCode" class="form-control" placeholder="Type a product code..." autocomplete="off" required>
                            <button class="btn btn-outline-dark btn-flat" id="btnAddProductCode" type="button">
                                <i class="bi bi-bag-plus"></i> Add
                            </button>
                        </div>
                    </div>
                </div>

                <hr class="horizontal dark">
                <div class="pb-2">
                    <table id="productcodesList" class="display table small " style="width:100%">
                        <thead>
                            <tr>
                                <th>Product Code</th>
                                <th>Plant Type</th>
                                <th>Product Family</th>
                                <th>Macro Package</th>
                                <th>Package</th>
                                <th>PLine</th>
                                <th>Maturity</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Card Change Password -->
        <div class="card mt-4" id="members">

            <div class="card-body">


                <div class="row">
                    <div class="col-4">
                        <h5>Members</h5>
                    </div>
                    <div class="col-8">
                        <form id="projectmemberForm" class="needs-validation" method="post" novalidate="">
                            <div class="input-group">
                                <select id="projectmemberSelect" name="projectmemberSelect" required class="form-select" placeholder="Search user to add (First Name, Last Name, Username, Email)"></select>
                                <button type="submit" id="AddMember" class="btn btn-outline-dark btn-flat"><i class="bi bi-person-fill-add"></i> Add</button>
                            </div>
                        </form>
                    </div>
                </div>
                <hr class="horizontal dark">
                <div class="pb-2">
                    <table id="tableMembers" class="display table small " style="width:100%">
                        <thead>
                            <tr>
                                <th class="col-8">Name</th>
                                <th class="col-2">Email</th>
                                <th class="col-1"></th>
                                <th class="col-1"></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>


            </div>
