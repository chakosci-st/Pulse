
@{
    ViewBag.Title = "Create project";
    ViewBag.SubTitle = "Initialize a new project using a roadmap template and assign team members.";
    ViewBag.TitleIcon = "bi bi-journal-plus";
    ViewBag.ContentHeaderMode = "breadcrumbs-only";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.IsActiveRegisterProject = "active";
}
@section styles{
    <!-- Datatables -->
    <link href="~/node_modules/datatables/media/css/jquery.dataTables.css" rel="stylesheet" />
    <link href="~/node_modules/datatables.net-bs5/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/node_modules/datatables.net-responsive-bs5/css/responsive.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/Content/datatables-bs5-fix.css" rel="stylesheet" />
    <!-- Select2 -->
    <link href="~/node_modules/select2/dist/css/select2.min.css" rel="stylesheet" />
    <link href="~/Content/locals/dynamic-fields.css" rel="stylesheet" />
    <link href="~/node_modules/flatpickr/dist/flatpickr.min.css" rel="stylesheet" />
    <!-- YearPicker -->
    <link href="~/Content/YearPicker/yearpicker.css" rel="stylesheet" />

    <!-- Icon Picker -->
    <link href="@Url.Content("~/node_modules/@simonwep/pickr/dist/themes/nano.min.css")" rel="stylesheet" />

    <!-- Local -->
    <link href="~/Content/Icon-Picker.css" rel="stylesheet" />

    <style>


        /* ======= BADGES ======= */
        .badge-soft {
            font-size: 0.7rem;
            border-radius: 999px;
            padding: 0.16rem 0.65rem;
            background: #e0ecff;
            color: #1d4ed8;
            border: 1px solid rgba(37,99,235,0.18);
        }

        .badge-maturity {
            font-size: 0.7rem;
            border-radius: 999px;
            padding: 0.08rem 0.5rem;
            background: #0f172a;
            color: #e5e7eb;
            border: 1px solid rgba(148,163,184,0.35);
        }

        .badge-required {
            font-size: 0.7rem;
            border-radius: 999px;
            padding: 0.08rem 0.5rem;
            background: rgba(220,38,38,0.07);
            color: #b91c1c;
            border: 1px solid rgba(248,113,113,0.6);
        }

        .badge-optional {
            font-size: 0.7rem;
            border-radius: 999px;
            padding: 0.08rem 0.5rem;
            background: rgba(16,185,129,0.06);
            color: #047857;
            border: 1px solid rgba(52,211,153,0.6);
        }

        /* ======= MEMBERS ======= */
        .member-pill {
            border-radius: 999px;
            padding: 0.2rem 0.6rem;
            background-color: #e5e7eb;
            color: #111827;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            margin: 0.15rem;
        }

            .member-pill button {
                border: none;
                background: transparent;
                padding: 0;
                font-size: 0.8rem;
                line-height: 1;
                color: #6b7280;
            }

                .member-pill button:hover {
                    color: #111827;
                }

        /* ======= MILESTONES & TASKS ======= */
        #milestonesContainer {
            display: flex;
            flex-direction: column;
            gap: 0.85rem;
        }

        .milestones-header-row {
            display: none;
            font-size: 0.75rem;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 0.25rem;
        }

        @@media (min-width: 768px) {
            .milestones-header-row {
                display: flex;
            }
        }

        .layout-main-card,
        .milestone-row,
        .milestone-body,
        .task-card {
            overflow: visible;
        }

        .milestone-row {
            background: #ffffff;
            border-radius: 1rem;
            border: 1px solid #e5e7eb;
            margin-bottom: 0;
            box-shadow: 0 4px 15px rgba(15,23,42,0.04);
            transition: box-shadow 0.15s ease, transform 0.15s ease;
        }

            .milestone-row:hover {
                box-shadow: 0 10px 25px rgba(15,23,42,0.08);
                transform: translateY(-1px);
            }

        .milestone-row--root {
            border-color: rgba(96, 165, 250, 0.45);
            box-shadow: 0 14px 28px rgba(59, 130, 246, 0.08);
        }

        .milestone-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            cursor: pointer;
            gap: 1rem;
            padding: 0.8rem 0.9rem;
            background: linear-gradient(90deg, #f9fafb, #eff6ff);
            border-bottom: 1px solid #e5e7eb;
        }

        .milestone-row--root .milestone-header {
            background: linear-gradient(90deg, #eff6ff, #f8fbff);
        }

        .milestone-title {
            font-size: 0.95rem;
            font-weight: 650;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

            .milestone-title i {
                font-size: 0.92rem;
            }

        .milestone-meta {
            font-size: 0.75rem;
            color: #6b7280;
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            align-items: center;
        }

        .milestone-summary-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.22rem 0.55rem;
            border-radius: 999px;
            border: 1px solid #dbe2ea;
            background: #ffffff;
            color: #475569;
            font-size: 0.73rem;
            line-height: 1.2;
        }

        .milestone-summary-chip--ok {
            background: rgba(16,185,129,0.08);
            border-color: rgba(16,185,129,0.2);
            color: #047857;
        }

        .milestone-summary-chip--warning {
            background: rgba(245,158,11,0.1);
            border-color: rgba(245,158,11,0.22);
            color: #b45309;
        }

        .milestone-summary-chip--neutral {
            background: #f8fafc;
            color: #475569;
        }

        .milestone-toggle-icon {
            font-size: 0.85rem;
            color: #6b7280;
            transition: transform 0.15s ease;
            margin-top: 0.1rem;
        }

        .milestone-header[aria-expanded="true"] .milestone-toggle-icon {
            transform: rotate(90deg);
        }

        .milestone-body {
            margin-top: 0;
            padding: 0.9rem;
            background-color: #ffffff;
        }

        .milestone-detail-grid {
            display: grid;
            grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.45fr);
            gap: 0.75rem;
            margin-bottom: 0.8rem;
        }

        .milestone-detail-card,
        .task-detail-card {
            padding: 0.85rem 0.9rem;
            border: 1px solid #e2e8f0;
            border-radius: 0.95rem;
            background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
        }

        .milestone-detail-card__label,
        .task-detail-card__label {
            display: block;
            margin-bottom: 0.6rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
        }

        .milestone-date-grid,
        .task-dates-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.65rem;
        }

        .milestone-field label,
        .task-field label {
            display: block;
            margin-bottom: 0.35rem;
            font-size: 0.75rem;
            font-weight: 600;
            color: #475569;
        }

        .milestone-root-note {
            display: flex;
            align-items: flex-start;
            gap: 0.65rem;
            padding: 0.85rem 0.95rem;
            border: 1px dashed rgba(96, 165, 250, 0.55);
            border-radius: 0.95rem;
            background: linear-gradient(135deg, rgba(239,246,255,0.95), rgba(248,250,252,0.95));
            color: #1d4ed8;
            font-size: 0.82rem;
            line-height: 1.55;
            margin-bottom: 0.8rem;
        }

        .tasks-container {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .task-row {
            padding: 0;
            border-bottom: none;
            font-size: 0.85rem;
        }

        .task-card {
            border: 1px solid #e5e7eb;
            border-radius: 0.95rem;
            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
        }

        .task-card--required {
            border-color: rgba(248,113,113,0.38);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.7), 0 10px 18px rgba(248,113,113,0.08);
        }

        .task-summary {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 0.85rem;
            padding: 0.82rem 0.92rem;
        }

        .task-summary__main {
            min-width: 0;
            display: grid;
            gap: 0.28rem;
        }

        .task-name {
            font-weight: 600;
            color: #111827;
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

            .task-name i {
                color: #4b5563;
                font-size: 0.8rem;
            }

        .task-meta {
            font-size: 0.72rem;
            color: #6b7280;
            margin-top: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
            align-items: center;
        }

        .task-summary__aside {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            align-items: center;
            justify-content: flex-end;
        }

        .task-summary-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.26rem 0.56rem;
            border: 1px solid #dbe2ea;
            border-radius: 999px;
            background: #f8fafc;
            color: #475569;
            font-size: 0.73rem;
            line-height: 1.2;
        }

        .task-summary-chip--ok {
            background: rgba(16,185,129,0.08);
            border-color: rgba(16,185,129,0.2);
            color: #047857;
        }

        .task-summary-chip--warning {
            background: rgba(245,158,11,0.1);
            border-color: rgba(245,158,11,0.22);
            color: #b45309;
        }

        .task-summary__toggle {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.35rem 0.72rem;
            border: none;
            border-radius: 999px;
            background: #e0ecff;
            color: #1d4ed8;
            font-size: 0.73rem;
            font-weight: 700;
            line-height: 1;
        }

            .task-summary__toggle i {
                transition: transform 0.15s ease;
            }

            .task-summary__toggle[aria-expanded="true"] i {
                transform: rotate(90deg);
            }

        .task-details {
            padding: 0 0.92rem 0.92rem;
        }

        .task-details__grid {
            display: grid;
            grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.45fr);
            gap: 0.75rem;
        }

        .owners-select-wrapper {
            position: relative;
            width: 100%;
        }

        .owners-input {
            min-height: 46px;
            padding: 4px 36px 4px 6px;
            border: 1px solid #d1d5db;
            border-radius: 0.85rem;
            background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.35rem;
            cursor: pointer;
        }

            .owners-input.focused {
                border-color: #2563eb;
                box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
                background-color: #ffffff;
            }

        .owners-chip {
            border-radius: 999px;
            padding: 0.16rem 0.5rem 0.16rem 0.24rem;
            background-color: #e0ecff;
            border: 1px solid #bfdbfe;
            color: #1f2937;
            font-size: 0.72rem;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            max-width: 100%;
        }

            .owners-chip button {
                border: none;
                background: transparent;
                padding: 0;
                font-size: 0.72rem;
                line-height: 1;
                color: #475569;
            }

        .owners-chip__avatar,
        .owners-item-avatar {
            width: 20px;
            height: 20px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 20px;
            font-size: 0.62rem;
            font-weight: 700;
            background: #1d4ed8;
            color: #ffffff;
        }

        .owners-chip__label {
            max-width: 108px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .owners-chip--overflow {
            border-style: dashed;
            background: #f8fafc;
            color: #475569;
            padding-inline: 0.58rem;
        }

        .owners-placeholder {
            font-size: 0.79rem;
            color: #9ca3af;
        }

        .owners-caret {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            pointer-events: none;
        }

        .owners-dropdown {
            position: absolute;
            left: 0;
            right: 0;
            top: calc(100% + 6px);
            z-index: 1051;
            background-color: #ffffff;
            border-radius: 0.85rem;
            box-shadow: 0 18px 34px rgba(15,23,42,0.2);
            border: 1px solid #e5e7eb;
            max-height: 220px;
            overflow-y: auto;
            font-size: 0.85rem;
        }

        .owners-item {
            padding: 0.45rem 0.7rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.6rem;
            cursor: pointer;
        }

            .owners-item:hover {
                background-color: #eff6ff;
            }

            .owners-item.active-owner {
                background-color: #e0ecff;
                font-weight: 500;
            }

        .owners-item-name {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            min-width: 0;
        }

        .owners-item-avatar {
            width: 26px;
            height: 26px;
            flex-basis: 26px;
            font-size: 0.68rem;
            background: #dbeafe;
            color: #1d4ed8;
        }

        .owners-item-text {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .owners-item-text strong,
        .owners-item-text small {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .owners-item-text strong {
            font-size: 0.78rem;
            color: #0f172a;
        }

        .owners-item-text small {
            font-size: 0.7rem;
            color: #64748b;
        }

        .owners-item-check {
            color: #2563eb;
            font-size: 0.8rem;
        }

        .owners-helper {
            font-size: 0.72rem;
            color: #6b7280;
            margin-top: 0.22rem;
        }

        .preview-title {
            font-size: 0.9rem;
            font-weight: 600;
        }

        .preview-sub {
            font-size: 0.78rem;
            color: #9ca3af;
        }

        @@media (max-width: 991px) {
            .milestone-detail-grid,
            .task-details__grid {
                grid-template-columns: minmax(0, 1fr);
            }

            .milestone-date-grid,
            .task-dates-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 767px) {
            .milestone-header,
            .task-summary {
                flex-direction: column;
            }

            .task-summary__aside {
                justify-content: flex-start;
            }

            .milestone-date-grid,
            .task-dates-grid {
                grid-template-columns: minmax(0, 1fr);
            }
        }


        .form-floating-date-picker {
            padding-left: 2.5rem; /* space for the icon */
        }

        .form-floating .input-icon-right {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            pointer-events: none; /* so clicks go to the input */
            color: #6c757d;
        }


        /* Red border for invalid Select2 control */
        .select2-container--default .select2-selection--single.is-invalid,
        .select2-container--default .select2-selection--multiple.is-invalid {
            border-color: #dc3545;
        }

        /* Example: warning icon as background */
        .select2-container--default .select2-selection--single.is-invalid {
            background-image: url("/path/to/warning-icon.svg");
            background-repeat: no-repeat;
            background-position: right 0.75rem center;
            background-size: 16px 16px;
        }

        .project-create-shell {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .project-create-hero {
            display: grid;
            grid-template-columns: minmax(0, 1.8fr) minmax(260px, 0.9fr);
            gap: 1rem;
            padding: 1.35rem 1.4rem;
            border: 1px solid rgba(191, 219, 254, 0.9);
            border-radius: 1.25rem;
            background:
                radial-gradient(circle at top right, rgba(59,130,246,0.16), transparent 34%),
                linear-gradient(135deg, #f8fbff 0%, #eef6ff 52%, #f8fafc 100%);
            box-shadow: 0 20px 48px rgba(15, 23, 42, 0.08);
        }

        .project-create-hero__eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.32rem 0.72rem;
            border-radius: 999px;
            font-size: 0.73rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #1d4ed8;
            background: rgba(219, 234, 254, 0.95);
            border: 1px solid rgba(147, 197, 253, 0.9);
            margin-bottom: 0.85rem;
        }

        .project-create-hero__title {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 0;
            color: #0f172a;
            font-size: clamp(1.35rem, 2vw, 1.95rem);
            font-weight: 700;
            line-height: 1.15;
        }

        .project-create-hero__title-icon {
            width: 48px;
            height: 48px;
            border-radius: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: #1d4ed8;
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            box-shadow: inset 0 0 0 1px rgba(96, 165, 250, 0.55);
        }

        .project-create-hero__copy {
            max-width: 64ch;
            margin: 0.8rem 0 0;
            color: #475569;
            font-size: 0.95rem;
            line-height: 1.65;
        }

        .project-create-hero__chips {
            display: flex;
            flex-wrap: wrap;
            gap: 0.55rem;
            margin-top: 1rem;
        }

        .project-create-hero__panel {
            display: grid;
            gap: 0.8rem;
            align-content: start;
        }

        .project-create-hero__stat {
            padding: 0.95rem 1rem;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.84);
            border: 1px solid rgba(226, 232, 240, 0.95);
            box-shadow: 0 12px 28px rgba(148, 163, 184, 0.16);
        }

        .project-create-hero__stat-label {
            display: block;
            margin-bottom: 0.28rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
        }

        .project-create-hero__stat strong {
            display: block;
            font-size: 0.96rem;
            color: #0f172a;
        }

        .project-create-main {
            border-radius: 1.25rem;
            border: 1px solid #e2e8f0;
            background: linear-gradient(180deg, #fcfdff 0%, #f8fafc 100%);
            box-shadow: 0 22px 50px rgba(15, 23, 42, 0.08);
        }

        .project-create-main__body {
            padding: 1.3rem;
        }

        .project-create-section {
            margin-bottom: 1rem;
            padding: 1.2rem;
            border-radius: 1.1rem;
            border: 1px solid #e2e8f0;
            background: #ffffff;
            box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
        }

        .project-create-section:last-of-type {
            margin-bottom: 0;
        }

        .project-create-section__header {
            margin-bottom: 1rem;
        }

        .project-create-section__header--actions {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .project-create-section__toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .project-create-info-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.85rem;
            margin-top: 0.85rem;
        }

        .project-create-info-card,
        .project-create-subsection,
        .project-create-note {
            border-radius: 1rem;
            border: 1px solid #e2e8f0;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.65);
        }

        .project-create-info-card {
            padding: 0.95rem 1rem;
        }

        .project-create-info-card__label {
            display: block;
            margin-bottom: 0.25rem;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
        }

        .project-create-info-card .form-control-plaintext {
            min-height: auto;
            margin: 0;
            color: #475569 !important;
        }

        .project-create-subsection {
            padding: 1rem;
            height: 100%;
            min-width: 0;
        }

        .project-create-subsection__header {
            margin-bottom: 0.8rem;
        }

        .project-create-subsection__title {
            margin: 0;
            font-size: 0.92rem;
            font-weight: 700;
            color: #0f172a;
        }

        .project-create-subsection__copy {
            margin: 0.25rem 0 0;
            font-size: 0.82rem;
            color: #64748b;
        }

        .project-create-shell .form-control,
        .project-create-shell .form-select,
        .project-create-shell .select2-container--default .select2-selection--single,
        .project-create-shell .select2-container--default .select2-selection--multiple {
            min-height: 48px;
            border-radius: 0.95rem;
            border-color: #cbd5e1;
            background-color: #ffffff;
            box-shadow: none;
        }

        .project-create-shell .form-control:focus,
        .project-create-shell .form-select:focus,
        .project-create-shell .select2-container--default.select2-container--focus .select2-selection--single,
        .project-create-shell .select2-container--default.select2-container--focus .select2-selection--multiple {
            border-color: #60a5fa;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.12);
        }

