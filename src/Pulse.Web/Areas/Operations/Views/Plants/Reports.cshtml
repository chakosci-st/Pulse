
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Reports";
    ViewBag.TitleIcon = "bi bi-bar-chart-line-fill";
    ViewBag.SubTitle = "Analyze plant coverage, site activity, and reporting patterns across manufacturing locations.";
    ViewBag.ContentHeaderChips = new[] { "Manufacturing sites", "Plant ownership", "Site-level template alignment" };
    ViewBag.ContentHeaderAsideLabel = "Plant insight";
    ViewBag.ContentHeaderAsideTitle = "See how manufacturing sites are represented across the template and reporting model.";
    ViewBag.ContentHeaderAsideBody = "Plant reporting helps surface which sites are active, how they are structured, and where master data may still need attention.";
    ViewBag.IsActiveOperationsPlants = "menu-open";
    ViewBag.IsActiveOperationsPlantsReports = "active";
    ViewBag.SelectedMenu = "Operations";
    ViewBag.IsActiveOperations = "active";
}
@section styles{
    <link href="~/Content/locals/stacked-userprofiles.css" rel="stylesheet" />
 
}


<div id="plantList" class="row">



    <!--begin::Col-->
    <div id="containerAdd" class="col-lg-4 col-md-6 col-12">
        <button id="btnAdd" type="button"
                class="btn btn-default w-100"
                style="height: 100%;">
            <h1><i class="bi bi-plus-circle-fill" style="font-size:80pt"></i></h1>
            <h5>Add new plant</h5>
        </button>
    </div>
    <!--end::Col-->
</div>


@section scripts{
    <script src="~/Scripts/locals/stacked-userprofiles.js"></script>
    <script src="~/Areas/Operations/Scripts/plants/reports.js"></script>
    <script>
        $(document).ready(function () {
            $('#btnAdd').on('click', function (e) {
                window.location.href = "@Url.Action("New", "Plants", new { area = "Operations" })";
            });
        });

    </script>
}








