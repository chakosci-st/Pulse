@model Pulse.Web.Areas.Settings.Models.DashboardViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var user = Model.User;
    ViewBag.IsActiveSettings = "active";
}

@section Styles {
    <style>
        .settings-hero {
            display: grid;
            grid-template-columns: minmax(0, 1.8fr) minmax(260px, 0.95fr);
            gap: 1rem;
            padding: 1.35rem 1.4rem;
            border: 1px solid rgba(191, 219, 254, 0.9);
            border-radius: 1.25rem;
            background: radial-gradient(circle at top right, rgba(14, 165, 233, 0.16), transparent 34%), linear-gradient(135deg, #f7fbff 0%, #eef8ff 52%, #f8fafc 100%);
            box-shadow: 0 20px 48px rgba(15, 23, 42, 0.08);
        }

        .settings-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.32rem 0.72rem;
            border-radius: 999px;
            font-size: 0.73rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #0369a1;
            background: rgba(224, 242, 254, 0.95);
            border: 1px solid rgba(125, 211, 252, 0.9);
            margin-bottom: 0.85rem;
        }

        .settings-title {
            display: flex;
            align-items: center;
            gap: 0.9rem;
            margin: 0;
            color: #0f172a;
            font-size: clamp(1.35rem, 2vw, 2rem);
            font-weight: 800;
            line-height: 1.15;
        }

        .settings-title__icon {
            width: 56px;
            height: 56px;
            border-radius: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            font-weight: 800;
            color: #0369a1;
            background: linear-gradient(135deg, #dbeafe 0%, #e0f2fe 100%);
            box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.4);
        }

        .settings-copy {
            max-width: 64ch;
            margin: 0.8rem 0 0;
            color: #475569;
            font-size: 0.95rem;
            line-height: 1.65;
        }

        .settings-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.55rem;
            margin-top: 1rem;
        }

        .settings-link-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.55rem 0.9rem;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.08);
            border: 1px solid rgba(148, 163, 184, 0.2);
            color: #0f172a;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 700;
        }

            .settings-link-chip:hover {
                color: #0f172a;
                border-color: rgba(96, 165, 250, 0.45);
                background: rgba(219, 234, 254, 0.92);
            }

        .settings-hero__panel {
            display: grid;
            gap: 0.8rem;
            align-content: start;
        }

        .settings-stat {
            padding: 0.95rem 1rem;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.86);
            border: 1px solid rgba(226, 232, 240, 0.95);
            box-shadow: 0 12px 28px rgba(148, 163, 184, 0.16);
        }

            .settings-stat label {
                display: block;
                margin-bottom: 0.28rem;
                font-size: 0.72rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: #64748b;
            }

            .settings-stat strong {
                display: block;
                font-size: 0.96rem;
                color: #0f172a;
            }

        .settings-grid {
            display: grid;
            grid-template-columns: minmax(0, 0.9fr) minmax(0, 2.1fr);
            gap: 1.25rem;
            margin-top: 1.25rem;
        }

        .settings-sidebar-card,
        .settings-section-card {
            border: 1px solid #e2e8f0;
            border-radius: 1rem;
            background: #fff;
            box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.05);
        }

        .settings-sidebar-card {
            position: sticky;
            top: 1rem;
        }

            .settings-sidebar-card .card-body,
            .settings-section-card .card-body {
                padding: 1.25rem;
            }

        .settings-section-label {
            font-size: 0.86rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #475569;
            margin-bottom: 0.95rem;
        }

        .settings-nav {
            display: grid;
            gap: 0.55rem;
        }

            .settings-nav a {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 0.75rem;
                padding: 0.8rem 0.9rem;
                border-radius: 0.8rem;
                text-decoration: none;
                color: #0f172a;
                background: #f8fafc;
                border: 1px solid transparent;
                font-weight: 600;
                font-size: 0.9rem;
            }

                .settings-nav a:hover {
                    border-color: #bfdbfe;
                    background: #eff6ff;
                    color: #1d4ed8;
                }

        .settings-note {
            margin-top: 1rem;
            padding: 0.9rem;
            border-radius: 0.85rem;
            background: #eff6ff;
            color: #1e3a8a;
            font-size: 0.84rem;
        }

        .settings-content {
            display: grid;
            gap: 1.25rem;
        }

        .settings-section-card h2 {
            margin-bottom: 0.4rem;
            font-size: 1.35rem;
            font-weight: 800;
            color: #0f172a;
        }

        .settings-section-card > .card-body > p {
            color: #64748b;
            font-size: 0.94rem;
            margin-bottom: 1rem;
        }

        .settings-callout-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.9rem;
        }

        .settings-callout {
            padding: 1rem;
            border: 1px solid #e2e8f0;
            border-radius: 0.9rem;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        }

            .settings-callout i {
                font-size: 1.2rem;
                color: #0f766e;
            }

            .settings-callout h3 {
                margin-top: 0.7rem;
                margin-bottom: 0.45rem;
                font-size: 1rem;
                font-weight: 700;
                color: #0f172a;
            }

            .settings-callout p {
                margin: 0;
                color: #64748b;
                font-size: 0.86rem;
            }

        .settings-pill-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.65rem;
        }

        .settings-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.6rem 0.85rem;
            border-radius: 999px;
            border: 1px solid #bfdbfe;
            background: #eff6ff;
            color: #1d4ed8;
            font-weight: 700;
            font-size: 0.84rem;
        }

        .settings-list {
            display: grid;
            gap: 0.9rem;
        }

        .settings-list-item {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 1rem;
            align-items: center;
            padding: 1rem;
            border: 1px solid #e2e8f0;
            border-radius: 0.95rem;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        }

            .settings-list-item h3 {
                margin: 0;
                font-size: 1rem;
                font-weight: 700;
                color: #0f172a;
            }

        .settings-list-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            margin-top: 0.55rem;
        }

            .settings-list-meta span {
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                font-size: 0.76rem;
                font-weight: 700;
                color: #475569;
                background: #f1f5f9;
                border-radius: 999px;
                padding: 0.32rem 0.6rem;
            }

        .settings-list-link {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            color: #1d4ed8;
            text-decoration: none;
            font-size: 0.86rem;
            font-weight: 700;
        }

            .settings-list-link:hover {
                color: #1e40af;
                text-decoration: none;
            }

        .settings-activity-list {
            display: grid;
            gap: 0.9rem;
        }

        .settings-activity-item {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            gap: 0.9rem;
            align-items: start;
            padding: 1rem;
            border: 1px solid #e2e8f0;
            border-radius: 0.95rem;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        }

        .settings-activity-icon {
            width: 42px;
            height: 42px;
            border-radius: 0.95rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #1d4ed8;
            background: #dbeafe;
            font-size: 1rem;
        }

        .settings-activity-item h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .settings-activity-item p {
            margin: 0.35rem 0 0;
            color: #64748b;
            font-size: 0.9rem;
            line-height: 1.55;
        }

        .settings-activity-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            margin-top: 0.6rem;
        }

            .settings-activity-meta span {
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                font-size: 0.76rem;
                font-weight: 700;
                color: #475569;
                background: #f1f5f9;
                border-radius: 999px;
                padding: 0.32rem 0.6rem;
            }

        .settings-activity-time {
            font-size: 0.8rem;
            color: #64748b;
            white-space: nowrap;
        }

        .settings-empty {
            padding: 1rem;
            border-radius: 0.95rem;
            border: 1px dashed #cbd5e1;
            background: #f8fafc;
            color: #64748b;
        }

        .settings-status--overdue {
            color: #b91c1c;
            background: #fee2e2;
        }

        @@media (max-width: 991.98px) {
            .settings-hero,
            .settings-grid,
            .settings-callout-grid {
                grid-template-columns: 1fr;
            }

            .settings-sidebar-card {
                position: static;
            }

            .settings-activity-item {
                grid-template-columns: auto minmax(0, 1fr);
            }

            .settings-activity-time {
                grid-column: 2;
            }
        }
    </style>
}

<section class="settings-hero">
    <div>
        <span class="settings-eyebrow">
            <i class="bi bi-sliders"></i>
            Settings Dashboard
        </span>
        <h1 class="settings-title">
            <span class="settings-title__icon">@Model.Initials</span>
            <span>
                @Model.FullName
                <small class="d-block mt-2" style="font-size:0.95rem;color:#64748b;font-weight:600;">@(!string.IsNullOrWhiteSpace(user.UserName) ? user.UserName : user.UserId)</small>
            </span>
        </h1>
        <p class="settings-copy">
            One place for your current workload, notifications, access footprint, and the fastest paths back into the parts of Pulse you use most.
        </p>
        <div class="settings-links">
            <a class="settings-link-chip" href="@Url.Action("Index", "Profile", new { area = "Settings", id = user.UserId })">
                <i class="bi bi-person-badge"></i>
                Open Profile
            </a>
            <a class="settings-link-chip" href="/Projects/ProjectTasks">
                <i class="bi bi-list-task"></i>
                View Tasks
            </a>
            <a class="settings-link-chip" href="/Home/Notifications">
                <i class="bi bi-bell"></i>
                Notifications
            </a>
            <a class="settings-link-chip" href="/Projects/Index">
                <i class="bi bi-kanban"></i>
                Projects
            </a>
        </div>
    </div>
    <div class="settings-hero__panel">
        <div class="settings-stat">
            <label>Pending Tasks</label>
            <strong>@Model.PendingTaskCount open assignments</strong>
        </div>
        <div class="settings-stat">
            <label>Unread Notifications</label>
            <strong>@Model.UnreadNotificationCount unread of @Model.ActiveNotificationCount active</strong>
        </div>
        <div class="settings-stat">
            <label>Projects Involved</label>
            <strong>@Model.ProjectCount active project contexts</strong>
        </div>
    </div>
</section>

<section class="settings-grid">
    <aside class="settings-sidebar-card card">
        <div class="card-body">
            <div class="settings-section-label">Quick Navigation</div>
            <nav class="settings-nav">
                <a href="#settings-overview">
                    <span>Overview</span>
                    <i class="bi bi-arrow-right-short"></i>
                </a>
                <a href="#settings-tasks">
                    <span>Due Soon Tasks</span>
                    <i class="bi bi-arrow-right-short"></i>
                </a>
                <a href="#settings-activity">
                    <span>Recent Activity</span>
                    <i class="bi bi-arrow-right-short"></i>
                </a>
                <a href="#settings-access">
                    <span>Access Snapshot</span>
                    <i class="bi bi-arrow-right-short"></i>
                </a>
            </nav>

            <div class="settings-note">
                This dashboard is intentionally personal: it keeps settings anchored to the current user rather than mixing in broad admin or template setup.
            </div>
        </div>
    </aside>

    <div class="settings-content">
        <section id="settings-overview" class="settings-section-card card">
            <div class="card-body">
                <div class="settings-section-label">Overview</div>
                <h2>Personal snapshot</h2>
                <p>Your highest-signal numbers for workload, updates, project reach, and access coverage.</p>

                <div class="settings-callout-grid">
                    <article class="settings-callout">
                        <i class="bi bi-list-task"></i>
                        <h3>@Model.PendingTaskCount Pending</h3>
                        <p>Open project-task assignments still requiring action.</p>
                    </article>
                    <article class="settings-callout">
                        <i class="bi bi-check2-square"></i>
                        <h3>@Model.CompletedTaskCount Completed</h3>
                        <p>Assignments already finished in your current task list.</p>
                    </article>
                    <article class="settings-callout">
                        <i class="bi bi-bell"></i>
                        <h3>@Model.ActiveNotificationCount Notifications</h3>
                        <p>Active updates visible to you across plant, project, and system contexts.</p>
                    </article>
                    <article class="settings-callout">
                        <i class="bi bi-people-fill"></i>
                        <h3>@Model.UserGroupCount Groups</h3>
                        <p>User groups currently shaping your access inside Pulse.</p>
                    </article>
                </div>
            </div>
        </section>

        <section id="settings-tasks" class="settings-section-card card">
            <div class="card-body">
                <div class="settings-section-label">Tasks</div>
                <h2>Due soon assignments</h2>
                <p>The nearest open tasks based on target completion date, with direct links back to project-task editing.</p>

                @if (Model.DueSoonTasks.Any())
                {
                    <div class="settings-list">
                        @foreach (var task in Model.DueSoonTasks)
                        {
                            <article class="settings-list-item">
                                <div>
                                    <h3>@task.ActivityName</h3>
                                    <div class="settings-list-meta">
                                        @if (!string.IsNullOrWhiteSpace(task.ProjectName))
                                        {
                                            <span>
                                                <i class="bi bi-kanban"></i>
                                                @task.ProjectName
                                            </span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(task.Status))
                                        {
                                            <span class="@(task.IsOverdue ? "settings-status--overdue" : string.Empty)">
                                                <i class="bi bi-flag"></i>
                                                @task.Status
                                            </span>
                                        }
                                        <span class="@(task.IsOverdue ? "settings-status--overdue" : string.Empty)">
                                            <i class="bi bi-calendar-event"></i>
                                            @(task.TargetCompletionDate.HasValue ? task.TargetCompletionDate.Value.ToString("dd MMM yyyy") : "No target date")
                                        </span>
                                    </div>
                                </div>
                                <a class="settings-list-link" href="/Projects/ProjectTasks/Edit/@task.ProjectTaskSysId">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                    Open task
                                </a>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="settings-empty">No due-soon tasks are available for this user.</div>
                }
            </div>
        </section>

        <section id="settings-activity" class="settings-section-card card">
            <div class="card-body">
                <div class="settings-section-label">Activity</div>
                <h2>Recent updates</h2>
                <p>Latest active notifications routed back to the underlying project, task, plant, or notification context.</p>

                @if (Model.RecentActivities.Any())
                {
                    <div class="settings-activity-list">
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <article class="settings-activity-item">
                                <span class="settings-activity-icon">
                                    <i class="bi @(activity.IsUnread ? "bi-bell-fill" : "bi-clock-history")"></i>
                                </span>
                                <div>
                                    <h3>@activity.Title</h3>
                                    @if (!string.IsNullOrWhiteSpace(activity.Message))
                                    {
                                        <p>@activity.Message</p>
                                    }
                                    <div class="settings-activity-meta">
                                        <span>
                                            <i class="bi bi-diagram-3"></i>
                                            @activity.Context
                                        </span>
                                        @if (!string.IsNullOrWhiteSpace(activity.CreatedBy))
                                        {
                                            <span>
                                                <i class="bi bi-person"></i>
                                                @activity.CreatedBy
                                            </span>
                                        }
                                        @if (activity.IsUnread)
                                        {
                                            <span>
                                                <i class="bi bi-dot"></i>
                                                Unread
                                            </span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(activity.TargetUrl))
                                    {
                                        <a class="settings-list-link mt-3" href="@activity.TargetUrl">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                            @(!string.IsNullOrWhiteSpace(activity.TargetLabel) ? activity.TargetLabel : "Open context")
                                        </a>
                                    }
                                </div>
                                <div class="settings-activity-time">@activity.OccurredAt.ToString("dd MMM yyyy hh:mm tt")</div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="settings-empty">No recent activity is available for this user.</div>
                }
            </div>
        </section>

        <section id="settings-access" class="settings-section-card card">
            <div class="card-body">
                <div class="settings-section-label">Access</div>
                <h2>Access snapshot</h2>
                <p>A quick reference to the user groups currently attached to this account.</p>

                @if (Model.UserGroups.Any())
                {
                    <div class="settings-pill-list">
                        @foreach (var groupName in Model.UserGroups)
                        {
                            <span class="settings-pill">
                                <i class="bi bi-people-fill"></i>
                                @groupName
                            </span>
                        }
                    </div>
                }
                else
                {
                    <div class="settings-empty">No user groups are assigned to this account.</div>
                }
            </div>
        </section>
    </div>
</section>