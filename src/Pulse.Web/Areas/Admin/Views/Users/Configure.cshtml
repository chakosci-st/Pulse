@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Configure User";
    ViewBag.TitleIcon = "bi bi-sliders2";
    ViewBag.SubTitle = "Manage user profile details, account status, and assigned user groups.";
    ViewBag.ContentHeaderChips = new[] { "User profile", "Group assignment", "Lifecycle control" };
    ViewBag.ContentHeaderAsideLabel = "What this controls";
    ViewBag.ContentHeaderAsideTitle = "Maintain one user end-to-end.";
    ViewBag.ContentHeaderAsideBody = "Use this screen for profile updates, access-group membership changes, and account lifecycle actions.";
    ViewBag.IsActiveAdminUsers = "menu-open";
    ViewBag.IsActiveAdminUsersAll = "active";
    ViewBag.SelectedMenu = "Admin";
}

@section Styles {
    <link href="~/node_modules/datatables/media/css/jquery.dataTables.css" rel="stylesheet" />
    <link href="~/node_modules/datatables.net-bs5/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/node_modules/datatables.net-responsive-bs5/css/responsive.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/Content/datatables-bs5-fix.css" rel="stylesheet" />
    <link href="~/Content/locals/sticky-menu.css" rel="stylesheet" />
    <style>
        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 88px;
            padding: 0.3rem 0.75rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .status-pill-on {
            background: #dcfce7;
            color: #166534;
        }

        .status-pill-off {
            background: #fee2e2;
            color: #991b1b;
        }
    </style>
}

<div class="row mb-5">
    <div class="col-lg-3">
        <div class="configurable--sticky" style="--sticky-top: calc(362px + 2rem);">
            <div class="card" style="width:100%">
                <div class="menu--content">
                    <div class="card-body">
                        <h6>Configuration Navigator</h6>
                        <nav class="help-nav d-grid gap-2">
                            <a href="#profile" class="btn btn-light text-start">Profile</a>
                            <a href="#basic-info" class="btn btn-light text-start">Basic Info</a>
                            <a href="#groups" class="btn btn-light text-start">User Groups</a>
                            <a href="#plants" class="btn btn-light text-start">Plants</a>
                            <a href="#delete" class="btn btn-light text-start">Delete User</a>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-9 mt-lg-0 mt-4">
        <div class="card card-body" id="profile">
            <div class="row justify-content-center align-items-center">
                <div class="col-sm-auto col-8 my-auto">
                    <div class="h-100">
                        <h5 class="mb-1 font-weight-bolder"><label id="labelName">Name</label></h5>
                        <p class="mb-0 font-weight-normal text-sm"><label id="labelDescription">User profile</label></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-4" id="basic-info">
            <div class="card-body pt-0">
                <div class="py-2">
                    <h5>Basic Info</h5>
                    <p class="section-subtitle">Set the user details.</p>
                </div>
                <form id="formBasicInfo" class="needs-validation" novalidate>
                    @Html.Hidden("Id")
                    @Html.Hidden("TransactionKey")
                    @Html.Hidden("IsActive")

                    <div class="row">
                        <div class="col-12">
                            <div class="form-group mb-3">
                                <label for="UserId" class="form-label">User ID</label>
                                <input type="text" class="form-control" id="UserId" name="UserId" readonly>
                            </div>
                            <div class="form-group mb-3">
                                <label for="UserName" class="form-label">User Name<span class="required-indicator sr-only"> (required)</span></label>
                                <div class="input-group has-validation">
                                    <input type="text" class="form-control" id="UserName" name="UserName" required>
                                    <div class="invalid-feedback" style="display:none;">Please provide a user name.</div>
                                </div>
                            </div>
                            <div class="form-group mb-3">
                                <label for="FirstName" class="form-label">First Name<span class="required-indicator sr-only"> (required)</span></label>
                                <div class="input-group has-validation">
                                    <input type="text" class="form-control" id="FirstName" name="FirstName" required>
                                    <div class="invalid-feedback" style="display:none;">Please provide a first name.</div>
                                </div>
                            </div>
                            <div class="form-group mb-3">
                                <label for="LastName" class="form-label">Last Name<span class="required-indicator sr-only"> (required)</span></label>
                                <div class="input-group has-validation">
                                    <input type="text" class="form-control" id="LastName" name="LastName" required>
                                    <div class="invalid-feedback" style="display:none;">Please provide a last name.</div>
                                </div>
                            </div>
                            <div class="form-group mb-3">
                                <label for="Email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="Email" name="Email">
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 d-flex justify-content-end">
                            <button class="btn btn-outline-dark" type="submit">Update basic info</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card mt-4" id="groups">
            <div class="card-body">
                <h5>User Groups</h5>
                <p class="text-sm mb-0">Toggle memberships for this user.</p>
                <hr class="horizontal dark">
                <div class="pb-2">
                    <table id="tableGroups" class="display table small" style="width:100%">
                        <thead>
                            <tr>
                                <th>Group Name</th>
                                <th>Description</th>
                                <th class="text-center">Assigned</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card mt-4" id="plants">
            <div class="card-body">
                <h5>Plants</h5>
                <p class="text-sm mb-0">Allow or restrict this user per plant, then configure plant user groups for each allowed plant.</p>
                <hr class="horizontal dark">
                <div class="pb-2">
                    <table id="tablePlants" class="display table small" style="width:100%">
                        <thead>
                            <tr>
                                <th>Plant</th>
                                <th class="text-center">Allowed</th>
                                <th class="text-center">Set Up</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card mt-4" id="delete">
            <div class="card-body">
                <div class="d-flex align-items-center mb-sm-0 mb-4">
                    <div class="w-50">
                        <h5>Delete User</h5>
                        <p class="text-sm mb-0">Once you delete this user, there is no going back.</p>
                    </div>
                    <div class="w-50 text-end">
                        <form id="formDelete" class="needs-validation float-end" novalidate>
                            <button id="buttonDelete" class="btn bg-gradient-danger mb-0 ms-2" type="submit">Delete User</button>
                        </form>
                        <form id="formChangeStatus" class="needs-validation float-end" novalidate>
                            <button id="buttonIsActive" data-action="deactivate" class="btn btn-outline-secondary mb-3 mb-md-0 ms-auto" type="submit">Deactivate</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="userPlantAssignmentsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-1">Plant User Groups</h5>
                    <p id="userPlantAssignmentsSummary" class="text-muted mb-0">Assign plant user groups for this user.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>User Group</th>
                                <th>Description</th>
                                <th class="text-center">Assigned</th>
                            </tr>
                        </thead>
                        <tbody id="userPlantAssignmentsTableBody">
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">Select a plant setup action to load assignments.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script src="~/Scripts/locals/sticky-menu.js"></script>
    <script src="~/node_modules/datatables/media/js/jquery.dataTables.min.js"></script>
    <script src="~/node_modules/datatables.net/js/dataTables.min.js"></script>
    <script src="~/node_modules/datatables.net-bs5/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/node_modules/datatables.net-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/node_modules/datatables.net-responsive-bs5/js/responsive.bootstrap5.min.js"></script>
    <script src="~/node_modules/jquery-validation/dist/jquery.validate.min.js"></script>
    <script>
        var id = '@ViewBag.Id';
        $('#Id').val(id);
    </script>
    <script src="~/Areas/Admin/Scripts/users/configure.js"></script>
}
