
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Reports";
    ViewBag.TitleIcon = "bi bi-bar-chart-line-fill";
    ViewBag.SubTitle = "Analyze user group usage, assignments, and linked access coverage across Pulse.";
    ViewBag.ContentHeaderChips = new[] { "Assignment coverage", "Group activity", "Linked access insight" };
    ViewBag.ContentHeaderAsideLabel = "What this controls";
    ViewBag.ContentHeaderAsideTitle = "Measure how user groups are being used.";
    ViewBag.ContentHeaderAsideBody = "Use reporting to understand assignment patterns, group relevance, and whether linked access is aligned with the way users work.";
    ViewBag.IsActiveAdminUserGroups = "menu-open";
    ViewBag.IsActiveAdminUserGroupsReports = "active";
    ViewBag.SelectedMenu = "Admin";
}



<div id="usergroupList" class="row">



    <!--begin::Col-->
    <div id="containerAdd" class="col-lg-4 col-md-6 col-12">
        <button id="btnAdd" type="button"
                class="btn btn-default w-100"
                style="height: 100%;">
            <h1><i class="bi bi-plus-circle-fill" style="font-size:80pt"></i></h1>
            <h5>Add new user group</h5>
        </button>
    </div>
    <!--end::Col-->
</div>


@section scripts{

    <script src="~/Areas/Admin/Scripts/usergroups/reports.js"></script>
    <script>
        $(document).ready(function () {
            $('#btnAdd').on('click', function (e) {
                window.location.href = "@Url.Action("New", "UserGroups", new { area = "Admin" })";
            });
        });

    </script>
}








