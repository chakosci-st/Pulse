
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "User Groups";
    ViewBag.TitleIcon = "bi bi-people-fill";
    ViewBag.SubTitle = "Review the assignable user groups that link users to consistent access across Pulse.";
    ViewBag.ContentHeaderChips = new[] { "Assignable groups", "Linkable access", "User-to-group mapping" };
    ViewBag.ContentHeaderAsideLabel = "What this controls";
    ViewBag.ContentHeaderAsideTitle = "Bundle access into assignable user groups.";
    ViewBag.ContentHeaderAsideBody = "User groups package linkable access so users inherit the right permissions without one-off manual mapping.";
    ViewBag.IsActiveAdminUserGroups = "menu-open";
    ViewBag.IsActiveAdminUserGroupsAll = "active";
    ViewBag.SelectedMenu = "Admin";
}

@section Styles {
    <link href="~/Content/locals/stacked-userprofiles.css" rel="stylesheet" />
    <style>


        .avatar-circle {
            width: 32px;
            height: 32px;
            border-radius: 999px;
            background-color: #374151;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #f9fafb;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Shared rounded look */
        .card {
            border-radius: 0.75rem;
            border: 1px solid #e5e7eb;
            box-shadow: 0 2px 6px rgba(15, 23, 42, 0.06);
        }

        .btn {
            border-radius: 999px;
        }

        .btn-xs {
            padding: 0.15rem 0.6rem;
            font-size: 0.75rem;
            line-height: 1.3;
        }

        .font-weight-semibold {
            font-weight: 600;
        }

        .request-card {
            transition: transform 0.08s ease, box-shadow 0.08s ease, background-color 0.08s ease;
        }

            .request-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(15, 23, 42, 0.16);
                background-color: #f9fafb;
            }

        .request-extra {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .status-badge {
            font-size: 0.7rem;
            padding: 0.15rem 0.55rem;
            border-radius: 999px;
            text-transform: uppercase;
        }

        .avatar-sm {
            width: 32px;
            height: 32px;
            border-radius: 999px;
            background-color: #c4b5fd;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #312e81;
            font-weight: 600;
            font-size: 0.8rem;
        }

        .request-actions .btn {
            margin-bottom: 0.15rem;
        }

        @@media (max-width: 992px) {
            .request-card .d-lg-flex {
                flex-direction: column !important;
                align-items: flex-start !important;
            }

            .request-card .request-actions {
                align-items: flex-start !important;
                margin-top: 0.5rem;
            }
        }

        .table-filter-toolbar {
            display: grid;
            grid-template-columns: minmax(180px, max-content) minmax(180px, 220px) minmax(220px, 260px) minmax(300px, 1fr);
            gap: 0.85rem;
            align-items: stretch;
            margin-bottom: 1rem;
            padding: 1rem;
            border: 1px solid #dbe4ea;
            border-radius: 1rem;
            background: linear-gradient(135deg, #f8fbfd 0%, #eef6f9 100%);
            box-shadow: 0 16px 36px rgba(15, 23, 42, 0.06);
        }

            .table-filter-toolbar > * {
                min-width: 0;
            }

            .table-filter-toolbar .table-filter-toolbar__item {
                display: flex;
                align-items: stretch;
                min-width: 0;
            }

                .table-filter-toolbar .table-filter-toolbar__item .btn,
                .table-filter-toolbar .table-filter-toolbar__item .form-select,
                .table-filter-toolbar .table-filter-toolbar__item .form-control {
                    width: 100%;
                }

                .table-filter-toolbar .table-filter-toolbar__item .btn {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    white-space: nowrap;
                }

            .table-filter-toolbar .card-tools-usergroupsTable-length,
            .table-filter-toolbar .card-tools-usergroupsTable-filter,
            .table-filter-toolbar .toolbar-search {
                width: 100%;
                min-width: 0;
            }

            .table-filter-toolbar .dt-length,
            .table-filter-toolbar .dt-search {
                width: 100%;
                margin: 0;
            }

            .table-filter-toolbar .dt-length label,
            .table-filter-toolbar .dt-search label {
                display: flex;
                align-items: center;
                width: 100%;
                min-height: 46px;
                margin: 0;
                gap: 0.65rem;
                color: #475569;
                font-size: 0.88rem;
                font-weight: 600;
            }

            .table-filter-toolbar .dt-length select,
            .table-filter-toolbar .dt-search input {
                width: 100%;
                min-width: 0;
                min-height: 46px;
                margin: 0;
                border-radius: 0.8rem;
                border: 1px solid #cbd5e1;
                background: #ffffff;
                color: #0f172a;
                box-shadow: none;
            }

            .table-filter-toolbar .dt-search input {
                padding-inline: 0.9rem;
            }

            .table-filter-toolbar .dt-search input::placeholder {
                color: #94a3b8;
            }

        @@media (max-width: 1399px) {
            .table-filter-toolbar {
                grid-template-columns: repeat(3, minmax(180px, 1fr));
            }

                .table-filter-toolbar .toolbar-search {
                    grid-column: span 2;
                }
        }

        @@media (max-width: 991px) {
            .table-filter-toolbar {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

                .table-filter-toolbar .toolbar-search {
                    grid-column: span 2;
                }
        }

        @@media (max-width: 767px) {
            .table-filter-toolbar {
                grid-template-columns: minmax(0, 1fr);
            }

                .table-filter-toolbar .toolbar-search {
                    grid-column: auto;
                }
        }
    </style>
}
<!--begin::Row-->

<div class="table-filter-toolbar">
    <div class="table-filter-toolbar__item">
        <a href="/Admin/usergroups/new" type="button" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> New User Group
        </a>
    </div>
    <div class="table-filter-toolbar__item">
        <select class="form-select" id="isActiveFilter">
            <option value="">All</option>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </select>
    </div>
    <div class="table-filter-toolbar__item">
        <span class="card-tools-usergroupsTable-length"></span>
    </div>
    <div class="table-filter-toolbar__item toolbar-search">
        <span class="card-tools-usergroupsTable-filter"></span>
    </div>
</div>

<div class="card-body p-0">
    <table id="usergroupsTable" class="display" style="width:100%;">
        <thead>
            <tr>
                <th></th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>
<!-- /.card-body -->
<div class="card-footer clearfix">
    <div class="card-tools-usergroupsTable-size" style="float:left"></div> <div class="card-tools-usergroupsTable-pagination float-end"></div>
</div>
<!-- /.card-footer -->


@section scripts{
    <script src="~/node_modules/datatables/media/js/jquery.dataTables.min.js"></script>
    <script src="~/node_modules/datatables.net/js/dataTables.min.js"></script>
    <script src="~/node_modules/datatables.net-bs5/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/node_modules/datatables.net-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/node_modules/datatables.net-responsive-bs5/js/responsive.bootstrap5.min.js"></script>
    <script src="~/Areas/Admin/Scripts/usergroups/index.js"></script>
}
