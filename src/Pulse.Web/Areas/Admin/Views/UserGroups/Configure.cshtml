
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Configure User Group";
    ViewBag.TitleIcon = "bi bi-sliders2";
    ViewBag.SubTitle = "Link access rights to the selected user group so assigned users inherit the right permissions.";
    ViewBag.ContentHeaderChips = new[] { "Linkable access", "Group-to-right mapping", "Inherited permissions" };
    ViewBag.ContentHeaderAsideLabel = "What this controls";
    ViewBag.ContentHeaderAsideTitle = "Map the access that this group should carry.";
    ViewBag.ContentHeaderAsideBody = "Configuration determines which rights follow the group, so user assignments stay predictable and easy to maintain.";
    ViewBag.IsActiveAdminUserGroups = "menu-open";
    ViewBag.IsActiveAdminUserGroupsAll = "active";
    ViewBag.SelectedMenu = "Admin";
}
@section Styles {
    <!-- Datatables -->
    <link href="~/node_modules/datatables/media/css/jquery.dataTables.css" rel="stylesheet" />
    <link href="~/node_modules/datatables.net-bs5/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/node_modules/datatables.net-responsive-bs5/css/responsive.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/Content/datatables-bs5-fix.css" rel="stylesheet" />
    <!-- Select2 -->
    <link href="~/node_modules/select2/dist/css/select2.min.css" rel="stylesheet" />
    <!-- local-floating menu -->
    <link href="~/Content/locals/sticky-menu.css" rel="stylesheet" />

    <style>
        .help-sidebar-card {
            border: 1px solid #e2e8f0;
            border-radius: 1rem;
            background: #fff;
            box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.05);
        }

            .help-sidebar-card .card-body {
                padding: 1.25rem;
            }

        .help-sidebar-title {
            font-size: 0.86rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #475569;
            margin-bottom: 0.95rem;
        }

        .help-nav {
            display: grid;
            gap: 0.55rem;
        }

        .help-nav-label {
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
        }

            .help-nav a {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 0.75rem;
                padding: 0.8rem 0.9rem;
                border-radius: 0.8rem;
                text-decoration: none;
                color: #0f172a;
                background: #f8fafc;
                border: 1px solid transparent;
                font-weight: 600;
                font-size: 0.9rem;
            }

                .help-nav a:hover {
                    border-color: #bfdbfe;
                    background: #eff6ff;
                    color: #1d4ed8;
                }

        .help-mini-note {
            margin-top: 1rem;
            padding: 0.9rem;
            border-radius: 0.9rem;
            background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 100%);
            color: #475569;
            font-size: 0.84rem;
            line-height: 1.6;
            border: 1px solid rgba(191, 219, 254, 0.9);
        }
    </style>
}
<div class="row mb-5">
    <div class="col-lg-3">
        <div class="configurable--sticky" style="--sticky-top: calc(362px + 2rem);">
            <div class="card help-sidebar-card" style="width:100%">
                <div class="menu--content">
                    <div class="card-body">
                        <div class="help-sidebar-title">Configuration Navigator</div>
                        <nav class="help-nav">
                            <a href="#profile"><span class="help-nav-label"><i class="bi bi-building"></i><span>Profile</span></span><i class="bi bi-arrow-right"></i></a>
                            <a href="#basic-info"><span class="help-nav-label"><i class="bi bi-receipt"></i><span>Basic Info</span></span><i class="bi bi-arrow-right"></i></a>
                            <a href="#modules"><span class="help-nav-label"><i class="bi bi-puzzle"></i><span>Modules</span></span><i class="bi bi-arrow-right"></i></a>
                            <a href="#members"><span class="help-nav-label"><i class="bi bi-person-vcard"></i><span>Members</span></span><i class="bi bi-arrow-right"></i></a>
                            <a href="#delete"><span class="help-nav-label"><i class="bi bi-trash"></i><span>Delete User Group</span></span><i class="bi bi-arrow-right"></i></a>
                        </nav>
                        <div class="help-mini-note">
                            Review the user group profile, manage access, and update membership from one floating navigation panel.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-9 mt-lg-0 mt-4">
        <!-- Card Profile -->
        <div class="card card-body" id="profile">
            <div class="row justify-content-center align-items-center">

                <div class="col-sm-auto col-8 my-auto">
                    <div class="h-100">
                        <h5 class="mb-1 font-weight-bolder">
                            <label id="labelName">Name</label>
                        </h5>
                        <p class="mb-0 font-weight-normal text-sm">
                            <label id="labelDescription">Description</label>
                        </p>
                    </div>
                </div>
                <div class="col-sm-auto ms-sm-auto mt-sm-0 mt-3 d-flex">
                    @*<label class="form-check-label mb-0">
                            <small id="profileVisibility">
                                Switch to active
                            </small>
                        </label>
                        <div class="form-check form-switch ms-2 my-auto">
                            <input class="form-check-input" type="checkbox" id="isActive" checked="">
                        </div>*@
                </div>
            </div>
        </div>
        <!-- Card Basic Info -->
        <div class="card mt-4" id="basic-info">

            <div class="card-body pt-0">
                <div class="py-2">
                    <h5>Basic Info</h5>
                    <p class="section-subtitle">Set the user group details.</p>
                </div>
                <form id="formBasicInfo" class="needs-validation" novalidate="">
                    @Html.Hidden("Id")
                    @Html.Hidden("TransactionKey")
                    @Html.Hidden("IsActive")
                    <!--begin::Row-->
                    <div class="row">
                        <div class="col-12">
                            <div class="form-group mb-3">
                                <label for="Name" class="form-label">User Group Name<span class="required-indicator sr-only"> (required)</span></label>
                                <div class="input-group has-validation">
                                    <input type="text" class="form-control" id="Name" name="Name" placeholder="Enter User Group Name" required="">
                                    <div class="invalid-feedback" style="display: none;">Please provide a user group name.</div>
                                </div>
                            </div>
                            <div class="form-group mb-3">
                                <label for="Name" class="form-label">User Group Description</label>
                                <div class="input-group has-validation">
                                    <input type="text" class="form-control" id="Description" name="Description" placeholder="Enter User Group Description">
                                </div>
                            </div>
                        </div>
                        <!-- /.col -->
                    </div>
                    <!--end::Row-->
                    <div class="row">
                        <div class="col-12">
                            <button onclick="$('#formBasicInfo').submit();" class="btn btn-outline-dark m-0 float-end" type="button">Update basic info</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <!-- Card Product Codes -->
        <div class="card mt-4" id="modules">


            <div class="card-body">


                <div class="row">
                    <div class="col-6">
                        <h5>Modules</h5>
                        <p class="text-sm mb-0">Defined module(s) that is referenced for this user group.</p>
                    </div>
                    <div class="col-6" id="moduleTools">

                    </div>
                </div>

                <hr class="horizontal dark">
                <div class="pb-2">
                    <table id="tableModules" class="display table small " style="width:100%">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Card Change Password -->
        <div class="card mt-4" id="members">

            <div class="card-body">


                <div class="row">
                    <div class="col-6">
                        <h5>Members</h5>
                    </div>
                    <div class="col-6">
                        <form id="formAddMember" class="needs-validation" method="post" novalidate="">
                            <div class="d-flex align-items-stretch gap-1">
                                <select id="UserSearch" style="width: 100%;" name="UserSearch" required class="form-control" placeholder="Search user to add (First Name, Last Name, Username, Email)"></select>
                                <span class="input-group-append">
                                    <button type="submit" id="AddMember" class="btn btn-outline-dark btn-flat">Add</button>
                                </span>
                            </div>
                        </form>
                    </div>
                </div>
                <hr class="horizontal dark">
                <div class="pb-2">
                    <table id="tableMembers" class="display table" style="width:100%">
                        <thead>
                            <tr>
                                <th class="col-4">First Name</th>
                                <th class="col-4">Last Name</th>
                                <th class="col-3">Email</th>
                                <th class="col-1"></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>


            </div>
        </div>

        <!-- Card Accounts -->
        <div class="card mt-4" id="accounts" style="display:none">
            <div class="card-header">
                <h5>Accounts</h5>
                <p class="text-sm">Here you can setup and manage your integration settings.</p>
            </div>
            <div class="card-body pt-0">
                <div class="d-flex">
                    <img class="width-48-px" src="../../assets/img/small-logos/logo-slack.svg" alt="logo_slack">
                    <div class="my-auto ms-3">
                        <div class="h-100">
                            <h5 class="mb-0">Slack</h5>
                            <a class="text-sm text-body" href="javascript:;">Show less <i class="fas fa-chevron-up text-xs ms-1" aria-hidden="true"></i></a>
                        </div>
                    </div>
                    <p class="text-sm text-secondary ms-auto me-3 my-auto">Enabled</p>
                    <div class="form-check form-switch my-auto">
                        <input class="form-check-input" checked="" type="checkbox" id="flexSwitchCheckDefault1">
                    </div>
                </div>
                <div class="ps-5 pt-3 ms-3">
                    <p class="mb-0 text-sm">You haven't added your Slack yet or you aren't authorized. Please add our Slack Bot to your account by clicking on <a href="javascript">here</a>. When you've added the bot, send your verification code that you have received.</p>
                    <div class="d-sm-flex bg-gray-100 border-radius-lg p-2 my-4 is-filled">
                        <p class="text-sm font-weight-bold my-auto ps-sm-2">Verification Code</p>
                        <input class="form-control form-control-sm ms-sm-auto mt-sm-0 mt-2 w-sm-15 w-40" type="text" value="1172913" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="Copy!" data-bs-original-title="Copy!" onfocus="focused(this)" onfocusout="defocused(this)">
                    </div>
                    <div class="d-sm-flex bg-gray-100 border-radius-lg p-2 my-4">
                        <p class="text-sm font-weight-bold my-auto ps-sm-2">Connected account</p>
                        <h6 class="text-sm ms-auto me-3 my-auto">hello@creative-tim.com</h6>
                        <button class="btn btn-sm bg-gradient-dark my-sm-auto mt-2 mb-0" type="button" name="button">Delete</button>
                    </div>
                </div>
                <hr class="horizontal dark">
                <div class="d-flex">
                    <img class="width-48-px" src="../../assets/img/small-logos/logo-spotify.svg" alt="logo_spotify">
                    <div class="my-auto ms-3">
                        <div class="h-100">
                            <h5 class="mb-0">Spotify</h5>
                            <p class="mb-0 text-sm">Music</p>
                        </div>
                    </div>
                    <p class="text-sm text-secondary ms-auto me-3 my-auto">Enabled</p>
                    <div class="form-check form-switch my-auto">
                        <input class="form-check-input" checked="" type="checkbox" id="flexSwitchCheckDefault2">
                    </div>
                </div>
                <hr class="horizontal dark">
                <div class="d-flex">
                    <img class="width-48-px" src="../../assets/img/small-logos/logo-atlassian.svg" alt="logo_atlassian">
                    <div class="my-auto ms-3">
                        <div class="h-100">
                            <h5 class="mb-0">Atlassian</h5>
                            <p class="mb-0 text-sm">Payment vendor</p>
                        </div>
                    </div>
                    <p class="text-sm text-secondary ms-auto me-3 my-auto">Enabled</p>
                    <div class="form-check form-switch my-auto">
                        <input class="form-check-input" checked="" type="checkbox" id="flexSwitchCheckDefault3">
                    </div>
                </div>
                <hr class="horizontal dark">
                <div class="d-flex">
                    <img class="width-48-px" src="../../assets/img/small-logos/logo-asana.svg" alt="logo_asana">
                    <div class="my-auto ms-3">
                        <div class="h-100">
                            <h5 class="mb-0">Asana</h5>
                            <p class="mb-0 text-sm">Organize your team</p>
                        </div>
                    </div>
                    <div class="form-check form-switch ms-auto my-auto">
                        <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault4">
                    </div>
                </div>
            </div>
        </div>
        <!-- Card Delete/Change Status -->
        <div class="card mt-4" id="delete">
            <div class="card-body">
                <div class="d-flex align-items-center mb-sm-0 mb-4">
                    <div class="w-50">
                        <h5>Delete User Group</h5>
                        <p class="text-sm mb-0">Once you delete this user group, there is no going back. Please be certain.</p>
                    </div>
                    <div class="w-50 text-end">
                        <form id="formDelete" class="needs-validation float-end" novalidate>
                            <button id="buttonDelete" onclick="$('#formDelete').submit();" class="btn bg-gradient-danger mb-0 ms-2" type="button">Delete User Group</button>
                        </form>
                        <form id="formChangeStatus" class="needs-validation float-end" novalidate>
                            <button id="buttonIsActive" onclick="$('#formChangeStatus').submit();" data-action="deactivate" class="btn btn-outline-secondary mb-3 mb-md-0 ms-auto" type="button">Deactivate</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>




@section scripts{
    <script src="~/Scripts/locals/sticky-menu.js"></script>
    <!-- datatables -->
    <script src="~/node_modules/datatables/media/js/jquery.dataTables.min.js"></script>
    <script src="~/node_modules/datatables.net/js/dataTables.min.js"></script>
    <script src="~/node_modules/datatables.net-bs5/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/node_modules/datatables.net-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/node_modules/datatables.net-responsive-bs5/js/responsive.bootstrap5.min.js"></script>
    <!-- Select2 -->
    <script src="~/node_modules/select2/dist/js/select2.min.js"></script>
    <!-- jquery-validate -->
    <script src="~/node_modules/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/Scripts/locals/switch-button.js"></script>
    <script>
        var id = '@ViewBag.Id';
        $('#Id').val(id);
    </script>
    <script src="~/Areas/Admin/Scripts/usergroups/configure.js"></script>
}