
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "New Module";
    ViewBag.TitleIcon = "bi bi-plus-circle";
    ViewBag.SubTitle = "Create an access right that can be assigned to users and used in access control.";
    ViewBag.ContentHeaderChips = new[] { "Access rights", "Assignable permissions", "Security setup" };
    ViewBag.ContentHeaderAsideLabel = "What this controls";
    ViewBag.ContentHeaderAsideTitle = "Add a new permission to the access catalog.";
    ViewBag.ContentHeaderAsideBody = "Define the right here so it can be assigned consistently through your user access model instead of handled as an exception.";
    ViewBag.IsActiveAdminModules = "menu-open";
    ViewBag.IsActiveAdminModulesNew = "active";
    ViewBag.SelectedMenu = "Admin";
}


<form id="moduleForm" class="needs-validation" novalidate=""> 
    <!--begin::Row-->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-lg">
                <div class="card-body">
                    <h5 class=" mb-3">
                        New Module
                        <br />
                        <small style="font-size:12pt; font-weight:normal">Create new module</small>
                    </h5>
                    <div class="form-group mb-3">
                        <label for="Code" class="form-label">Module Code<span class="required-indicator sr-only"> (required)</span></label>
                        <div class="input-group has-validation">
                            <input type="text" class="form-control" id="Code" name="Code" placeholder="Enter Valid Module Code" required="">
                            <div class="invalid-feedback">Please provide a valid module code.</div>
                        </div>
                    </div>
                    <div class="form-group mb-3">
                        <label for="Name" class="form-label">Module Name<span class="required-indicator sr-only"> (required)</span></label>
                        <div class="input-group has-validation">
                            <input type="text" class="form-control" id="Name" name="Name" placeholder="Enter Module Name" required="">
                            <div class="invalid-feedback">Please provide a module name.</div>
                        </div>
                    </div>
                    <div class="form-group mb-3">
                        <label for="Description" class="form-label">Module Description</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="Description" name="Description" placeholder="Enter Module Description">
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
                <div class="card-footer clearfix">
                    <div class="  m-0 float-end">
                        <a href="@Url.Action("Index", "Modules", new { area = "Admin" })" class="btn btn-default">Cancel</a> <button class="btn btn-success">Save</button>
                    </div>
                </div>
                <!-- /.card-footer -->
            </div>
        </div>
        <!-- /.col -->
    </div>
    <!--end::Row-->
</form>






@section scripts{
    <script src="~/node_modules/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/Areas/Admin/Scripts/modules/new.js"></script>
    <script>
 
    </script>
}
