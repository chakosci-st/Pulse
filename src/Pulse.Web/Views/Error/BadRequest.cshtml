@{
    ViewData["Title"] = "";
    Layout = "~/Views/Shared/_Layout.cshtml";
} 
<div class="container   d-flex flex-column justify-content-center align-items-center" style="margin-top:200px">
    <div class="card shadow-lg border-0" style="min-width: 500px;">
        <div class="card-body text-center">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 3rem;"></i>
            </div>
            <h2 class="mb-3">404 - Page Not Found</h2>
            <p class="card-text text-muted mb-4">
                Sorry, the page you are looking for does not exist.
            </p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-house-door-fill me-2"></i>Back to Home
            </a>
        </div>
    </div>
</div>

