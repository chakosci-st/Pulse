@{


    var area = ViewContext.RouteData.DataTokens["area"] as string;
    string menuPartial;
    switch (area)
    {
        case "Templates":
            menuPartial = "~/Areas/Templates/Views/Shared/_SidebarMenu.cshtml";
            break;
        case "Sites":
            menuPartial = "~/Areas/Sites/Views/Shared/_SidebarMenu.cshtml";
            break;
        case "Admin":
            menuPartial = "~/Areas/Admin/Views/Shared/_SidebarMenu.cshtml";
            break;
        case "Operations":
            menuPartial = "~/Areas/Operations/Views/Shared/_SidebarMenu.cshtml";
            break;
        default:
            menuPartial = "~/Views/Shared/_SidebarMenu.cshtml";
            break;
    }

    if (!string.IsNullOrEmpty(ViewBag.OverrideMenuPartial))
    {
        menuPartial = ViewBag.OverrideMenuPartial;
    }

}


<aside class="app-sidebar bg-primary-subtle" data-bs-theme="dark">
    <!--begin::Sidebar Brand-->
    @Html.Partial("_SidebarBrand")
    <!--end::Sidebar Brand-->
    <!--begin::Sidebar Wrapper-->
    <div class="sidebar-wrapper">
        <nav class="mt-2">
            <!--begin::Sidebar Menu-->
            @Html.Partial(menuPartial)
            <!--end::Sidebar Menu-->
        </nav>
    </div>
    <!--end::Sidebar Wrapper-->
</aside>