<!doctype html>
<html lang="en">
<!--begin::Head-->
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>PULSE | @ViewBag.Title</title>
    <!--begin::Accessibility Meta Tags-->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#007bff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)" />
    <!--end::Accessibility Meta Tags-->
    <!--begin::Primary Meta Tags-->
    <meta name="title" content="PULSE" />
    <meta name="author" content="Charles Riann Legaspi" />
    <meta name="description"
          content="Project Updates, Lifecylce, Scheduling & Execution: Keeping Your Projects on Track, Every Step of the Way." />
    <meta name="keywords"
          content="bootstrap 5, bootstrap, bootstrap 5 admin dashboard, bootstrap 5 dashboard, bootstrap 5 charts, bootstrap 5 calendar, bootstrap 5 datepicker, bootstrap 5 tables, bootstrap 5 datatable, vanilla js datatable, colorlibhq, colorlibhq dashboard, colorlibhq admin dashboard, accessible admin panel, WCAG compliant" />
    <!--end::Primary Meta Tags-->
    <!--begin::Accessibility Features-->
    <link href="~/node_modules/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Skip links will be dynamically added by accessibility.js -->
    <meta name="supported-color-schemes" content="light dark" />
    <link rel="preload" href="~/node_modules/admin-lte/dist/css/adminlte.min.css" as="style" />
    <!--end::Accessibility Features-->
    <!--begin::Fonts-->
    <link rel="stylesheet"
          href="@Url.Content("https://cdn.jsdelivr.net/npm/@fontsource/source-sans-3@5.0.12/index.css")"
          integrity="sha256-tXJfXfp6Ewt1ilPzLDtQnJV4hclT9XuaZUKyUvmyr+Q="
          crossorigin="anonymous"
          media="print"
          onload="this.media='all'" />
    <!--end::Fonts-->
    <!--begin::Third Party Plugin(OverlayScrollbars)-->
    <link href="~/node_modules/overlayscrollbars/styles/overlayscrollbars.min.css" rel="stylesheet" />
    <!--end::Third Party Plugin(OverlayScrollbars)-->
    <!--begin::Third Party Plugin(Bootstrap Icons)-->
    <link href="~/node_modules/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <!--end::Third Party Plugin(Bootstrap Icons)-->
    <!--begin::Required Plugin(AdminLTE)-->
    <link href="~/node_modules/admin-lte/dist/css/adminlte.min.css" rel="stylesheet" />
    <!--end::Required Plugin(AdminLTE)-->
    <!--begin::Toastr-->
    <link href="~/node_modules/toastr/build/toastr.min.css" rel="stylesheet" />
    <!--end::Toastr-->
    <!--begin::tippy-->
    <link href="~/node_modules/tippy.js/dist/tippy.css" rel="stylesheet" />
    <link href="~/node_modules/tippy.js/themes/material.css" rel="stylesheet" />
    <!--end::tippy-->



    <link href="@Url.Content("~/node_modules/@fortawesome/fontawesome-free/css/fontawesome.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/node_modules/@fortawesome/fontawesome-free/css/all.min.css")" rel="stylesheet" />

    @Styles.Render("~/Content/css")

    @RenderSection("Styles", required: false)


    <link href="~/Content/Site.css" rel="stylesheet" />
    <link href="~/Content/locals/chatbox.css" rel="stylesheet" />
    <style>
        .btn-tool {
            color: #fff
        }

            .btn-tool:hover {
                color: #f1e6e6 !important
            }

        .btn-list-key {
            color: #007bff !important;
            text-decoration: none !important;
            background-color: transparent !important;
        }

            .btn-list-key:hover {
                color: #0475ee !important;
                text-decoration: underline !important;
                background-color: transparent !important;
            }

        .small, small {
            font-size: 80%;
            font-weight: 400;
        }

        .text-muted {
            color: #6c757d !important;
        }
    </style>

</head>

<body class="layout-fixed sidebar-expand-lg sidebar-mini sidebar-collapse bg-body-tertiary">


    <!--begin::App Wrapper-->
    <div class="app-wrapper">
        <!--begin::Header-->
        @Html.Partial("_Header")
        <!--end::Header-->
        <!--begin::Sidebar-->
        @Html.Partial("_Sidebar")
        <!--end::Sidebar-->
        <!--begin::App Main-->
        <main class="app-main">

            @{
                var breadcrumbs = ViewBag.Breadcrumbs == null ? Enumerable.Empty<Pulse.Core.Entities.Breadcrumb>().ToList() : ViewBag.Breadcrumbs as List<Pulse.Core.Entities.Breadcrumb>;
            }


            <!--begin::App Content Header-->
            @Html.Partial("_ContentHeader", breadcrumbs)
            <div class="app-content">
                <!--begin::Container-->
                <div class="container-fluid">
                    @RenderBody()
                </div>
                <!--end::Container-->
            </div>
            <!--end::App Content-->
        </main>
        <!--end::App Main-->
        <!--begin::Footer-->
        @Html.Partial("_Footer")
        <!--end::Footer-->
    </div>

    <!--end::App Wrapper-->
    <!--begin::Script-->
    <!-- jQuery -->
    @Scripts.Render("~/bundles/jquery")
    <!--begin::Third Party Plugin(OverlayScrollbars)-->
    <script src="~/node_modules/overlayscrollbars/browser/overlayscrollbars.browser.es6.min.js"></script>
    <!--end::Third Party Plugin(OverlayScrollbars)-->
    <!--begin::Required Plugin(popperjs for Bootstrap 5)-->
    <script src="@Url.Content("~/node_modules/@popperjs/core/dist/umd/popper.min.js")"></script>
    <!--end::Required Plugin(popperjs for Bootstrap 5)-->
    <!--begin::Required Plugin(Bootstrap 5)-->
    <script src="~/node_modules/bootstrap/dist/js/bootstrap.min.js"></script>
    <!--end::Required Plugin(Bootstrap 5)-->
    <!--begin::Required Plugin(AdminLTE)-->
    <script src="~/node_modules/admin-lte/dist/js/adminlte.min.js"></script>
    <!--end::Required Plugin(AdminLTE)--><!--begin::OverlayScrollbars Configure-->
    <!--begin::Toastr-->
    <script src="~/node_modules/toastr/build/toastr.min.js"></script>
    <!--end::Toastr-->
    <!--begin::Bootbox-->
    <script src="~/node_modules/bootbox/dist/bootbox.min.js"></script>
    <!--end::Bootbox-->
    <!--begin::Moment-->
    <script src="~/node_modules/moment/min/moment.min.js"></script>
    <!--end::Moment-->
    <!--begin::tippy-->
    <script src="@Url.Content("~/node_modules/tippy.js/dist/tippy.umd.min.js")"></script>
    <!--end::tippy-->
    <!--begin::fontawesome-->
    <script src="@Url.Content("~/node_modules/@fortawesome/fontawesome-free/js/fontawesome.min.js")"></script>
    <script src="@Url.Content("~/node_modules/@fortawesome/fontawesome-free/js/all.min.js")"></script>
    <!--end::fontawesome-->
    <!--begin::signalr-->
    <script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
    <script src="~/signalr/hubs"></script>
    <!--end::signalr-->

    <script src="~/Scripts/locals/commonUtils.js"></script>
    <script src="~/Scripts/locals/layout.js"></script>


    <!--end::OverlayScrollbars Configure-->
    <script>
        (function () {
            var appRootPath = '@System.Configuration.ConfigurationManager.AppSettings["app:rootpath"]';
            var apiRootPath = '@System.Configuration.ConfigurationManager.AppSettings["api:rootpath"]';
            window.getAppRootPath = function () { return appRootPath; };
            window.getApiRootPath = function () { return apiRootPath; };
        })();

    </script>

    <script src="~/Scripts/locals/jwtToken.js"></script>

    <script>

 


        toastr.options = {
            "closeButton": true,
            "debug": false,
            "newestOnTop": false,
            "progressBar": true,
            "positionClass": "toast-top-center",
            "preventDuplicates": false,
            "onclick": null,
            "showDuration": "400",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut"
        }

        const SELECTOR_SIDEBAR_WRAPPER = '.sidebar-wrapper';
        const Default = {
            scrollbarTheme: 'os-theme-light',
            scrollbarAutoHide: 'leave',
            scrollbarClickScroll: true,
        };

        document.addEventListener('DOMContentLoaded', function () {
            tippy('[title]', {
                content(reference) {
                    const title = reference.getAttribute('title');
                    reference.removeAttribute('title');
                    return title;
                },
                placement: 'top',
                animation: 'scale',
                theme: 'material',
                arrow: true,
                delay: [100, 100]
            });
        });


        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll('.avatar-initials').forEach(function (el) {
                const parent = el.parentElement;
                const initials = el.textContent.trim();
                const baseFontSize = parseFloat(getComputedStyle(parent).width) * 0.5; // 50% of width

                // Adjust font size based on length
                let fontSize;
                if (initials.length <= 2) {
                    fontSize = baseFontSize;
                } else if (initials.length === 3) {
                    fontSize = baseFontSize * 0.8;
                } else if (initials.length === 4) {
                    fontSize = baseFontSize * 0.65;
                } else {
                    fontSize = baseFontSize * 0.5;
                }
                el.style.fontSize = fontSize + "px";
                el.style.lineHeight = getComputedStyle(parent).height; // vertical centering
            });
        });


        document.addEventListener('DOMContentLoaded', function () {
            const sidebarWrapper = document.querySelector(SELECTOR_SIDEBAR_WRAPPER);
            if (sidebarWrapper && OverlayScrollbarsGlobal ?.OverlayScrollbars !== undefined) {
                OverlayScrollbarsGlobal.OverlayScrollbars(sidebarWrapper, {
                    scrollbars: {
                        theme: Default.scrollbarTheme,
                        autoHide: Default.scrollbarAutoHide,
                        clickScroll: Default.scrollbarClickScroll,
                    },
                });
            }
        });

        $(document).ready(function () {
            $('#btnlogout').on('click', function () {
                var logoutdialog = bootbox.dialog({
                    message: "<p>You will be signed out of all <b>Web SSO-enabled INTRANET applications currently open</b> in this browser session. Please ensure you have saved all your work before proceeding.<br /><br />Do you want to continue?</p>",
                    title: "<p>SINGLE SIGN-OUT WARNING MESSAGE</p>",
                    buttons: [
                        {
                            label: "Logout",
                            className: "btn btn-primary pull-left",
                            callback: function () {
                                //location.href = '@Url.Action("Logout", "Auth")';


                                location.href = 'https://intrasso.st.com/idp/startSLO.ping?TargetResource=https%3A%2F%2Fpulse.cal.st.com%3A44344%2Fauth%2Flogout';



                      

                                //return true;



                            }
                        },
                        {
                            label: "Cancel",
                            className: "btn btn-default pull-left",
                            callback: function () {
                                logoutdialog.modal("hide");
                                return false;
                            }
                        }
                    ],
                    show: false,
                    onEscape: function () {
                        logoutdialog.modal("hide");
                        return false;
                    }
                });


                logoutdialog.modal('show');

                logoutdialog.modal('show').find(".modal-dialog")
                    .addClass("modal-dialog-centered");


            });
        });


    </script>
 
    <!--end::Script-->
 
    <script src="~/Areas/Projects/Scripts/projects/chatroom.js"></script>
    @RenderSection("scripts", required: false)
</body>
<!--end::Body-->
</html>




