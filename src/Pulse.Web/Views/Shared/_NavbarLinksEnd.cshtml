
@using Pulse.Web.Helpers
@{
    /**/


    var loggedUserId = User.Identity.GetClaim("employeeid");
    var loggedFirstName = User.Identity.GetClaim("firstname");
    var loggedLastName = User.Identity.GetClaim("lastname");
    var loggedUserGroups = User.Identity.GetClaim("usergroups");
    var loggedFullName = string.Join(" ", new[] { loggedFirstName, loggedLastName }.Where(value => !string.IsNullOrWhiteSpace(value))).Trim();
    var loggedProfilePhotoUrl = Url.Action("Photo", "Profile", new { area = "Settings", id = loggedUserId });

    string initialsFirstName = string.Concat(
    loggedFirstName
        ?.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries)
        .Select(fn => fn[0])
    );
    string initialsLastName = string.Concat(
            loggedLastName
                ?.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(fn => fn[0])
            );

    var loggedInitials = string.IsNullOrWhiteSpace(initialsFirstName + initialsLastName) ? "?" : initialsFirstName + initialsLastName;
}
<style>
    .navbar-badge {
        position: absolute;
        top: 9px;
        right: 1px;
        padding: 2px 4px;
        font-size: 0.6rem;
        font-weight: 400;
    }

    .dropdown-menu-lg {
        min-width: 280px;
        max-width: 300px;
        padding: 0;
    }

    .pulse-navbar-search-item {
        display: flex;
        align-items: center;
        margin-right: 0.35rem;
    }

    .pulse-navbar-search-shell {
        display: inline-flex;
        align-items: center;
        width: 42px;
        max-width: min(78vw, 440px);
        border: 1px solid transparent;
        border-radius: 999px;
        background: #ffffff;
        overflow: hidden;
        transition: width 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

        .pulse-navbar-search-shell.is-open {
            width: min(36vw, 420px);
            border-color: #cbd5e1;
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.12);
        }

    .pulse-navbar-search-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border: none;
        background: transparent;
        color: #0f172a;
        flex: 0 0 42px;
    }

    .pulse-navbar-search-form {
        display: flex;
        align-items: center;
        min-width: 0;
        width: calc(100% - 42px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.18s ease;
    }

    .pulse-navbar-search-shell.is-open .pulse-navbar-search-form {
        opacity: 1;
        pointer-events: auto;
    }

    .pulse-navbar-search-input {
        border: none;
        box-shadow: none;
        min-width: 0;
        padding-inline: 0.25rem;
        font-size: 0.9rem;
    }

        .pulse-navbar-search-input:focus {
            box-shadow: none;
        }

    .pulse-navbar-search-submit,
    .pulse-navbar-search-close {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border: none;
        background: transparent;
        color: #64748b;
        flex: 0 0 36px;
    }

        .pulse-navbar-search-submit:hover,
        .pulse-navbar-search-close:hover,
        .pulse-navbar-search-toggle:hover {
            color: #0f4c81;
        }

    @@media (max-width: 991.98px) {
        .pulse-navbar-search-shell.is-open {
            width: min(74vw, 360px);
        }
    }

    .pulse-user-menu-link {
        min-width: 280px;
    }

        .pulse-user-menu-link .row {
            align-items: center;
            flex-wrap: nowrap;
        }

    .pulse-user-meta {
        min-width: 0;
        margin-top: -10px;
        padding-left: 10px;
    }

        .pulse-user-meta strong,
        .pulse-user-meta small {
            display: block;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    @@media (max-width: 575.98px) {
        .pulse-user-menu-link {
            min-width: auto;
            padding-inline: 0.5rem;
        }

        .pulse-user-menu-link .row {
            margin: 0;
        }

        .pulse-user-menu-link .row > [class*="col-"] {
            width: auto;
            flex: 0 0 auto;
            max-width: none;
            padding-left: 0;
            padding-right: 0;
        }

        .pulse-user-meta {
            display: none;
        }
    }

    .pulse-user-dropdown {
        min-width: 360px;
        max-width: 380px;
        border: 1px solid #dbe4ea;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 22px 48px rgba(15, 23, 42, 0.16);
    }

    .pulse-user-header {
        background: linear-gradient(135deg, #0f4c81 0%, #0f766e 100%);
        color: #f8fafc;
        padding: 1.4rem 1.35rem 1.15rem;
    }

        .pulse-user-header p {
            margin: 0.9rem 0 0;
            line-height: 1.45;
            color: #e2e8f0;
        }

        .pulse-user-header small {
            display: block;
            color: #bfdbfe;
        }

    .pulse-user-summary {
        padding: 1rem;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .pulse-user-summary-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.8rem;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #475569;
    }

    .pulse-user-summary-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.7rem;
    }

    .pulse-user-stat {
        border: 1px solid #dbe4ea;
        border-radius: 0.9rem;
        padding: 0.8rem 0.85rem;
        background: #ffffff;
    }

    .pulse-user-stat-label {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #64748b;
    }

    .pulse-user-stat-value {
        display: block;
        margin-top: 0.3rem;
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
    }

    .pulse-user-links {
        padding: 0.6rem 0;
        background: #ffffff;
    }

    .pulse-user-link-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.8rem 1rem;
        color: #0f172a;
        text-decoration: none;
        transition: background-color 0.18s ease, color 0.18s ease;
    }

        .pulse-user-link-item:hover {
            background: #eff6ff;
            color: #0f4c81;
        }

    .pulse-user-link-copy {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        min-width: 0;
    }

        .pulse-user-link-copy i {
            font-size: 1rem;
            color: #0f766e;
        }

        .pulse-user-link-copy span {
            font-weight: 600;
        }

    .pulse-user-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 1rem;
        border-top: 1px solid #e2e8f0;
        background: #f8fafc;
    }

        .pulse-user-footer .btn {
            border-radius: 999px;
            padding-inline: 1rem;
        }

        .pulse-user-header {
            position: relative;
        }

        .pulse-user-header__settings {
            position: absolute;
            top: 0.9rem;
            right: 1rem;
            width: 2.25rem;
            height: 2.25rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            color: rgba(248, 250, 252, 0.92);
            background: rgba(15, 23, 42, 0.24);
            border: 1px solid rgba(255, 255, 255, 0.18);
            text-decoration: none;
            transition: background-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
        }

        .pulse-user-header__settings:hover {
            color: #ffffff;
            background: rgba(15, 23, 42, 0.38);
            transform: rotate(18deg);
        }

        .pulse-profile-avatar {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, #0f4c81 0%, #0f766e 100%);
            color: #f8fafc;
        }

        .pulse-profile-avatar--small {
            width: 2.5rem;
            height: 2.5rem;
        }

        .pulse-profile-avatar--large {
            width: 5rem;
            height: 5rem;
            border: 3px solid rgba(255, 255, 255, 0.25);
            box-shadow: 0 18px 30px rgba(15, 23, 42, 0.18);
        }

        .pulse-profile-avatar__image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

        .pulse-profile-avatar--loaded .pulse-profile-avatar__image {
            display: block;
        }

        .pulse-profile-avatar__initials {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: inherit;
        }

        .pulse-profile-avatar--small .pulse-profile-avatar__initials {
            font-size: 0.9rem;
        }

        .pulse-profile-avatar--large .pulse-profile-avatar__initials {
            font-size: 1.55rem;
        }

        .pulse-profile-avatar--loaded .pulse-profile-avatar__initials {
            display: none;
        }
</style>
<ul class="navbar-nav ms-auto">
    <!--begin::Navbar Search-->
    <li class="nav-item pulse-navbar-search-item">
        <div id="pulseNavbarSearchShell" class="pulse-navbar-search-shell">
            <button id="pulseNavbarSearchToggle" class="pulse-navbar-search-toggle" type="button" aria-label="Open global search" aria-expanded="false">
                <i class="bi bi-search"></i>
            </button>
            <form id="pulseNavbarSearchForm" class="pulse-navbar-search-form" action="/Home/Search" method="get" role="search">
                <input id="pulseNavbarSearchInput"
                       class="form-control pulse-navbar-search-input"
                       type="search"
                       name="q"
                       placeholder="Search projects, milestones, tasks, modules..."
                       aria-label="Global search" />
                <button class="pulse-navbar-search-submit" type="submit" aria-label="Search">
                    <i class="bi bi-arrow-right"></i>
                </button>
                <button id="pulseNavbarSearchClose" class="pulse-navbar-search-close" type="button" aria-label="Close search">
                    <i class="bi bi-x-lg"></i>
                </button>
            </form>
        </div>
    </li>
    <!--end::Navbar Search-->
    @Html.Partial("_NotificationBar")
    @Html.Partial("_MessageBar")
    <!--begin::Fullscreen Toggle-->
    <li class="nav-item">
        <a class="nav-link" href="#" data-lte-toggle="fullscreen">
            <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>

            <i data-lte-icon="minimize" class="bi bi-fullscreen-exit" style="display: none"></i>
        </a>
    </li>

    <!--end::Fullscreen Toggle-->
    <!--begin::User Menu Dropdown-->
    <li class="nav-item dropdown user-menu">
        <a href="#" class="nav-link dropdown-toggle pulse-user-menu-link" data-bs-toggle="dropdown">
            <div class="row">
                <div class="col-2">
                    <div class="pulse-profile-avatar pulse-profile-avatar--small shadow" style="margin-top:-10px;" title="@loggedFullName">
                        <img class="pulse-profile-avatar__image"
                             src="@loggedProfilePhotoUrl"
                             alt="@loggedFullName"
                             onload="this.closest('.pulse-profile-avatar').classList.add('pulse-profile-avatar--loaded');"
                             onerror="this.remove();" />
                        <span class="pulse-profile-avatar__initials">@loggedInitials</span>
                    </div>

                </div>
                <div class="col-10">
                    <div class="pulse-user-meta">
                        <strong>@loggedFirstName @loggedLastName</strong><small>@loggedUserGroups</small>
                    </div>
                </div>
            </div>
        </a>
        <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end pulse-user-dropdown">
            <!--begin::User Image-->
            <li class="user-header pulse-user-header" data-bs-theme="dark">
                <a href="/Settings/Profile" class="pulse-user-header__settings" aria-label="Open profile settings">
                    <i class="bi bi-gear"></i>
                </a>
                <div class="avatar-container center">
                    <div class="pulse-profile-avatar pulse-profile-avatar--large shadow" title="@loggedFullName">
                        <img class="pulse-profile-avatar__image"
                             src="@loggedProfilePhotoUrl"
                             alt="@loggedFullName"
                             onload="this.closest('.pulse-profile-avatar').classList.add('pulse-profile-avatar--loaded');"
                             onerror="this.remove();" />
                        <span class="pulse-profile-avatar__initials">@loggedInitials</span>
                    </div>
                </div>
                <p>
                    @loggedFirstName @loggedLastName
                    <small>@loggedUserId</small>
                    <small>@loggedUserGroups</small>
                </p>
            </li>
            <!--end::User Image-->
            <!--begin::Menu Body-->
            <li class="user-body pulse-user-summary">
                <div class="pulse-user-summary-title">
                    <span>My Snapshot</span>
                    <span id="userMenuSummaryState">Live</span>
                </div>
                <div class="pulse-user-summary-grid">
                    <div class="pulse-user-stat">
                        <span class="pulse-user-stat-label">Active Projects</span>
                        <span id="userMenuProjectsCount" class="pulse-user-stat-value">--</span>
                    </div>
                    <div class="pulse-user-stat">
                        <span class="pulse-user-stat-label">In Progress Tasks</span>
                        <span id="userMenuTasksCount" class="pulse-user-stat-value">--</span>
                    </div>
                    <div class="pulse-user-stat">
                        <span class="pulse-user-stat-label">Overdue Items</span>
                        <span id="userMenuDueCount" class="pulse-user-stat-value">--</span>
                    </div>
                    <div class="pulse-user-stat">
                        <span class="pulse-user-stat-label">Unread Chats</span>
                        <span id="userMenuMessagesCount" class="pulse-user-stat-value">0</span>
                    </div>
                </div>
            </li>
            <!--end::Menu Body-->
            <li class="pulse-user-links">
                <a href="/Home/ViewProjects" class="pulse-user-link-item">
                    <span class="pulse-user-link-copy"><i class="bi bi-kanban"></i><span>Project View</span></span>
                    <i class="bi bi-chevron-right"></i>
                </a>
                <a href="/Chats" class="pulse-user-link-item">
                    <span class="pulse-user-link-copy"><i class="bi bi-chat-dots"></i><span>Messages</span></span>
                    <i class="bi bi-chevron-right"></i>
                </a>

                <a href="/Home/Notifications" class="pulse-user-link-item">
                    <span class="pulse-user-link-copy"><i class="bi bi-bell"></i><span>Notifications</span></span>
                    <i class="bi bi-chevron-right"></i>
                </a>

                <a href="/Home/Guide" class="pulse-user-link-item">
                    <span class="pulse-user-link-copy"><i class="bi bi-question-circle"></i><span>Help Center</span></span>
                    <i class="bi bi-chevron-right"></i>
                </a>
                <a href="/Home/UserGuide" class="pulse-user-link-item">
                    <span class="pulse-user-link-copy"><i class="bi bi-journal-bookmark"></i><span>User Guide</span></span>
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
            <!--begin::Menu Footer-->
            <li class="user-footer pulse-user-footer">
                <a href="/Home/ViewProjects" class="btn btn-outline-primary btn-flat">Open Workspace</a>
                <button id="btnlogout" class="btn btn-default btn-flat float-end">Sign out</button>
            </li>
            <!--end::Menu Footer-->
        </ul>
    </li>
    <!--end::User Menu Dropdown-->
</ul>
