@{
    ViewBag.Title = "Project Chats";
    ViewBag.TitleIcon = "bi bi-chat-dots-fill";
    ViewBag.IsActiveChat = "active";
    Layout = "~/Views/Shared/_Layout.cshtml"; // or your layout
    ViewBag.ContentHeaderMode = "breadcrumbs-only";
}

<section class="chat-page-hero">
    <div>
        <span class="chat-page-hero__eyebrow"><i class="bi bi-chat-square-text"></i> Project collaboration</span>
        <h1>Conversations stay close to the work.</h1>
        <p>Move between project rooms, follow the live thread, and keep delivery discussion anchored to the portfolio context instead of buried in separate tools.</p>
        <div class="chat-page-hero__chips">
            <span class="chat-page-hero__chip"><i class="bi bi-briefcase"></i> Project room directory</span>
            <span class="chat-page-hero__chip"><i class="bi bi-lightning-charge"></i> Live message flow</span>
            <span class="chat-page-hero__chip"><i class="bi bi-search"></i> Quick room lookup</span>
        </div>
    </div>
    <aside class="chat-page-hero__panel">
        <div class="chat-page-hero__panel-label">How to use it</div>
        <ul>
            <li><i class="bi bi-1-circle"></i> Search for the project room on the left</li>
            <li><i class="bi bi-2-circle"></i> Open the thread to load the latest discussion</li>
            <li><i class="bi bi-3-circle"></i> Reply without leaving the workspace</li>
        </ul>
    </aside>
</section>

<div id="chatApp" class="chat-app-container">
    <!-- Left: Rooms list -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <h5 class="mb-1">Projects</h5>
            <input type="text" id="roomSearch" class="form-control form-control-sm" placeholder="Search projects..." />
        </div>
        <div id="roomList" class="chat-room-list">
            <!-- Rooms will be rendered here via JS -->
            <!-- Example item structure:
            <div class="chat-room-item" data-room-id="P-12345">
                <div class="chat-room-icon" style="background-color:#0d6efd;">
                    <i class="bi bi-briefcase-fill"></i>
                </div>
                <div class="chat-room-info">
                    <div class="chat-room-name">Project 12345</div>
                    <div class="chat-room-subtitle text-muted">Some description...</div>
                </div>
                <div class="chat-room-badge badge bg-danger rounded-pill">3</div>
            </div>
            -->
        </div>
    </div>

    <!-- Right: Chat area -->
    <div class="chat-main">
        <!-- Header -->
        <div class="chat-main-header">
            <div class="chat-room-header-info">
                <div id="chatRoomIcon" class="chat-room-icon me-2" style="display:none;">
                    <!-- icon inserted by JS -->
                </div>
                <div>
                    <div id="chatRoomName" class="fw-semibold">Select a project to start chatting</div>
                    <div id="chatRoomSubtitle" class="chat-room-subtitle text-muted"></div>
                </div>
            </div>
        </div>

        <!-- Messages -->
        <div id="chatMessages" class="chat-main-messages">
            <!-- chat bubbles -->
        </div>

        <!-- Typing indicator -->
        <div id="typingIndicator" class="chat-typing-indicator text-muted fs-7" style="display:none;"></div>

        <!-- Input -->
        <div class="chat-main-input">
            <div class="input-group">
                <input type="text"
                       id="chatInput"
                       class="form-control"
                       placeholder="Type a message..."
                       autocomplete="off" />
                <button id="chatSubmit" class="btn btn-primary" type="button">
                    <i class="bi bi-send-fill"></i> <!-- or font-awesome -->
                </button>
            </div>
        </div>
    </div>
</div>

@section styles {
    <style>
        .chat-page-hero {
            position: relative;
            overflow: hidden;
            display: grid;
            grid-template-columns: minmax(0, 1.7fr) minmax(260px, 0.95fr);
            gap: 1rem;
            padding: 1.45rem 1.55rem;
            margin-bottom: 1rem;
            border-radius: 1.45rem;
            border: 1px solid rgba(148, 163, 184, 0.26);
            background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 46%, #eff6ff 100%);
            box-shadow: 0 22px 48px rgba(15, 23, 42, 0.12);
        }

            .chat-page-hero::after {
                content: "";
                position: absolute;
                inset: auto -80px -90px auto;
                width: 240px;
                height: 240px;
                border-radius: 999px;
                background: radial-gradient(circle, rgba(191, 219, 254, 0.28) 0%, rgba(191, 219, 254, 0) 72%);
                pointer-events: none;
            }

        .chat-page-hero__eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.35rem 0.8rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.12);
            color: #dbeafe;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .chat-page-hero h1 {
            margin: 0.85rem 0 0.45rem;
            font-size: clamp(2rem, 2.8vw, 2.65rem);
            font-weight: 800;
            letter-spacing: -0.04em;
            color: #f8fafc;
        }

        .chat-page-hero p {
            margin: 0;
            max-width: 720px;
            color: rgba(226, 232, 240, 0.84);
            line-height: 1.7;
        }

        .chat-page-hero__chips {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            margin-top: 0.95rem;
        }

        .chat-page-hero__chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.52rem 0.74rem;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.24);
            border: 1px solid rgba(219, 234, 254, 0.16);
            color: #e0f2fe;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .chat-page-hero__panel {
            position: relative;
            z-index: 1;
            padding: 1rem;
            border-radius: 1.2rem;
            background: rgba(255, 255, 255, 0.92);
            color: #0f172a;
            box-shadow: 0 18px 32px rgba(30, 41, 59, 0.12);
        }

        .chat-page-hero__panel-label {
            margin-bottom: 0.7rem;
            color: #475569;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .chat-page-hero__panel ul {
            display: grid;
            gap: 0.55rem;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .chat-page-hero__panel li {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.55rem 0.65rem;
            border-radius: 0.85rem;
            background: #eff6ff;
            color: #1e3a8a;
            font-size: 0.84rem;
            font-weight: 600;
        }

        /* Layout */
        .chat-app-container {
            display: flex;
            height: calc(100dvh - 170px);
            min-height: 420px;
            border: 1px solid #dee2e6;
            border-radius: 0.5rem;
            overflow: hidden;
            background: #fff;
        }

        .chat-sidebar {
            width: 280px;
            border-right: 1px solid #dee2e6;
            display: flex;
            flex-direction: column;
            background: #f8f9fa;
        }

        .chat-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #ffffff;
        }

        /* Sidebar header */
        .chat-sidebar-header {
            padding: 0.75rem;
            border-bottom: 1px solid #dee2e6;
            background: #f8f9fa;
        }

            .chat-sidebar-header h5 {
                font-size: 0.95rem;
            }

            .chat-sidebar-header input {
                margin-top: 0.35rem;
            }

        /* Room list */
        .chat-room-list {
            flex: 1;
            overflow-y: auto;
        }

        .chat-room-item {
            display: flex;
            align-items: center;
            padding: 0.5rem 0.75rem;
            cursor: pointer;
            border-bottom: 1px solid #e9ecef;
            transition: background-color 0.15s;
        }

            .chat-room-item:hover {
                background: #e9f2ff;
            }

            .chat-room-item.active {
                background: #dbe7ff;
            }

        .chat-room-icon {
            width: 32px;
            height: 32px;
            border-radius: 999px;
            background: #0d6efd;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .chat-room-info {
            flex: 1;
            margin-left: 0.5rem;
        }

        .chat-room-name {
            font-size: 0.9rem;
            font-weight: 500;
        }

        .chat-room-subtitle {
            font-size: 0.75rem;
            color: #6c757d;
        }

        .chat-room-badge {
            font-size: 0.7rem;
        }

        /* Chat header */
        .chat-main-header {
            padding: 0.6rem 0.9rem;
            border-bottom: 1px solid #dee2e6;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .chat-room-header-info {
            display: flex;
            align-items: center;
        }

        /* Messages area */
        .chat-main-messages {
            flex: 1;
            padding: 0.75rem 0.9rem;
            overflow-y: auto;
            background: #f1f3f5;
        }

        .chat-typing-indicator {
            padding: 0 0.9rem 0.25rem 0.9rem;
        }

        /* Input */
        .chat-main-input {
            padding: 0.5rem 0.9rem;
            border-top: 1px solid #dee2e6;
            background: #f8f9fa;
        }

        /* Bubbles – using your existing classes but you can adjust */
 

        .direct-chat-text {
 
            background: #ffffff;
            border: 1px solid #dee2e6;
        }

        .direct-chat-msg.end .direct-chat-text {
            background: #0d6efd !important;
            color: #fff !important;
            border-color: #0d6efd !important;
        }

        .direct-chat-img.chat-avatar-msg {
            width: 32px;
            height: 32px;
            border-radius: 999px;
            background: #6c757d;
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 0.8rem;
            flex-shrink: 0;
        }

        .direct-chat-msg.end .direct-chat-img {
            order: 2;
            margin-left: 0.4rem;
        }

        .direct-chat-msg.end .direct-chat-text {
            order: 1;
        }

        .chat-status {
            margin-left: 0.4rem;
        }

        @@media (max-width: 991px) {
            .chat-page-hero {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@section scripts{
    <script src="~/Scripts/chats/chatview.js"></script>

}