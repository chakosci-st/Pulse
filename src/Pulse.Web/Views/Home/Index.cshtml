                <i class="bi bi-folder-check"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text">ACTIVE PROJECTS</span>
                <span class="info-box-number activeproducts">
                    0
                </span>
            </div>
            <!-- /.info-box-content -->
        </div>
        <!-- /.info-box -->
    </div>
