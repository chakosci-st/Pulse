<div class="analytics-card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
            <div>
                <div class="analytics-kicker">Decision Support</div>
                <div class="analytics-title">Portfolio Health At A Glance</div>
                <div class="analytics-copy">
                    Charts below turn the live project feed into workload, progress, and deadline signals so users can see where action is needed first.
                </div>
            </div>
            <div class="text-muted" id="analyticsLastUpdated" style="font-size:0.8rem;">Waiting for dashboard data...</div>
        </div>

        <div class="analytics-grid">
            <div class="chart-panel">
                <div class="chart-shell">
                    <div class="chart-title">
                        <h3>Portfolio Status Mix</h3>
                        <span>Projects by current state</span>
                    </div>
                    <div id="portfolioStatusChart"></div>
                </div>
            </div>
            <div class="chart-panel">
                <div class="chart-shell">
                    <div class="chart-title">
                        <h3>Delivery Window</h3>
                        <span>Target completion pressure</span>
                    </div>
                    <div id="deliveryWindowChart"></div>
                </div>
            </div>
            <div class="chart-panel">
                <div class="chart-shell">
                    <div class="chart-title">
                        <h3>Completion Bands</h3>
                        <span>Projects grouped by completion</span>
                    </div>
                    <div id="completionBandChart"></div>
                </div>
            </div>
        </div>

        <div class="analytics-grid-secondary">
            <div class="chart-panel">
                <div class="chart-shell">
                    <div class="chart-title">
                        <h3>Owner Capacity Snapshot</h3>
                        <span>Top owners by project count</span>
                    </div>
                    <div id="ownerLoadChart"></div>
                </div>
            </div>
            <div class="chart-panel">
                <div class="chart-shell">
                    <div class="chart-title">
                        <h3>Suggested Focus</h3>
                        <span>Priorities generated from live counters</span>
                    </div>
                    <div id="dashboardInsights" class="insight-panel"></div>
                </div>
            </div>
        </div>

        <div class="analytics-footer">
            <div>Data source: <strong>Projects dashboard feed</strong> and <strong>live task counters</strong></div>
            <div id="analyticsCoverage">No project distribution loaded yet.</div>
        </div>
    </div>
</div>



<!-- ================= SUMMARY TABLE: PROJECTS & ROOT MILESTONES ================= -->
<div class="card card-main mb-4">
    <div class="card-body p-3 p-lg-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="section-title">Projects & Root Milestones (Summary)</span>
            <small class="text-muted" style="font-size:0.78rem;">
                One row per project & top-level milestone
            </small>
        </div>

        <div class="table-responsive">
            <table class="table table-sm align-middle" id="projectsRootMilestonesTable">
                <thead>
                    <tr>
                        <th style="width:26%">Project</th>
                        <th style="width:10%">Project Owner</th>
                        <th style="width:12%">Project Period</th>
                        <th style="width:8%">Proj. %</th>
                        <th style="width:10%">Project Status</th>
                        <th style="width:20%">Root Milestone</th>
                        <th style="width:12%">Milestone Period</th>
                        <th style="width:8%">Ms. %</th>
                        <th style="width:10%">Ms. Status</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<!-- ================= DETAILED TABLE: PROJECTS vs MILESTONES ================= -->
<div class="card card-main">
    <div class="card-body p-3 p-lg-4">

        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="section-title">Detailed Projects & Milestones</span>
        </div>

        <div class="pulse-index-toolbar mb-3">
            <div class="pulse-index-toolbar-field">
                <label for="filterProjectStatus">Project Status</label>
                <select class="form-select form-select-sm" id="filterProjectStatus">
                    <option value="">All</option>
                    <option value="Not Started">Not Started</option>
                    <option value="Ongoing">Ongoing</option>
                    <option value="Hold">Hold</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                    <option value="At Risk">At Risk</option>
                </select>
            </div>
            <div class="pulse-index-toolbar-field">
                <label for="filterMilestoneStatus">Milestone Status</label>
                <select class="form-select form-select-sm" id="filterMilestoneStatus">
                    <option value="">All</option>
                    <option value="Not Started">Not Started</option>
                    <option value="Ongoing">Ongoing</option>
                    <option value="Hold">Hold</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                    <option value="At Risk">At Risk</option>
                </select>
            </div>
            <div class="pulse-index-toolbar-field">
                <label for="filterOwner">Owner</label>
                <input type="text" class="form-control form-control-sm" id="filterOwner"
                       placeholder="Project or milestone owner">
            </div>
            <div class="pulse-index-toolbar-field">
                <label for="filterSearch">Search</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white">
                        <i class="fas fa-search text-gray-500"></i>
                    </span>
                    <input type="text" class="form-control" id="filterSearch"
                           placeholder="Project / milestone name">
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-sm align-middle" id="projectsMilestonesTable">
                <thead>
                    <tr>
                        <th style="width:32px;"></th>
                        <th>Project</th>
                        <th style="width:14%">Project Period</th>
                        <th style="width:8%">Proj. %</th>
                        <th style="width:10%">Project Owner</th>
                        <th style="width:10%">Project Status</th>
                        <th style="width:16%">Milestone / Period</th>
                        <th style="width:8%">Ms. %</th>
                        <th style="width:12%">Milestone Owner</th>
                        <th style="width:10%">Milestone Status</th>
                    </tr>
                </thead>
                <tbody id="projectsMilestonesBody">
                    <!-- rows will be injected here via JS -->
                </tbody>
            </table>
        </div>





    </div>
</div>

<div style="display:none">
    <div id="hdn-avatar-group-container"></div>
</div>
