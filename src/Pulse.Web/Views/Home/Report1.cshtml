@{
    ViewBag.Title = "Project Export";
    ViewBag.TitleIcon = "bi bi-bar-chart-line-fill";
    ViewBag.SubTitle = "Export project records into an Excel-ready file.";
    ViewBag.ContentHeaderChips = new[] { "Excel export", "Project records", "Portfolio filtering" };
    ViewBag.ContentHeaderAsideLabel = "What this report does";
    ViewBag.ContentHeaderAsideTitle = "Extract a filtered project dataset for offline analysis.";
    ViewBag.ContentHeaderAsideBody = "Use search and status filters to narrow the project set, then export a clean Excel-ready snapshot for sharing, audit, or follow-up work outside Pulse.";
}

@section Styles {
    <style>
        .report1-shell {
            display: grid;
            gap: 1rem;
        }

        .report1-toolbar {
            display: grid;
            grid-template-columns: minmax(0, 1.4fr) repeat(2, minmax(180px, 0.6fr)) auto;
            gap: 0.85rem;
            align-items: center;
            padding: 1rem;
            border: 1px solid #dbe4ea;
            border-radius: 1rem;
            background: linear-gradient(135deg, #f8fbfd 0%, #eef6f9 100%);
            box-shadow: 0 16px 36px rgba(15, 23, 42, 0.06);
        }

        .report1-toolbar .form-control,
        .report1-toolbar .form-select,
        .report1-toolbar .btn {
            min-height: 46px;
            border-radius: 0.8rem;
        }

        .report1-toolbar .btn {
            min-width: 170px;
            font-weight: 700;
        }

        .report1-summary {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            padding: 0 0.25rem;
        }

        .report1-summary-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: #0f172a;
        }

        .report1-summary-copy {
            font-size: 0.9rem;
            color: #64748b;
        }

        .report1-count {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.55rem 0.9rem;
            border-radius: 999px;
            background: #ecfeff;
            color: #155e75;
            font-size: 0.86rem;
            font-weight: 700;
        }

        .report1-table-card {
            overflow: hidden;
            border: 1px solid #dbe4ea;
            border-radius: 1rem;
            background: #ffffff;
            box-shadow: 0 18px 36px rgba(15, 23, 42, 0.06);
        }

        .report1-table-wrap {
            overflow: auto;
        }

        .report1-table {
            width: 100%;
            min-width: 1280px;
            border-collapse: separate;
            border-spacing: 0;
        }

        .report1-table thead th {
            position: sticky;
            top: 0;
            z-index: 1;
            padding: 0.85rem 0.8rem;
            background: #0f172a;
            color: #f8fafc;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .report1-table tbody td {
            padding: 0.85rem 0.8rem;
            border-top: 1px solid #e2e8f0;
            vertical-align: middle;
            font-size: 0.86rem;
            color: #334155;
            white-space: nowrap;
        }

        .report1-table tbody tr:nth-child(even) td {
            background: #f8fafc;
        }

        .report1-project-cell {
            min-width: 240px;
        }

        .report1-project-name {
            font-weight: 700;
            color: #0f172a;
        }

        .report1-project-meta {
            font-size: 0.78rem;
            color: #64748b;
        }

        .report1-number {
            text-align: right;
            font-variant-numeric: tabular-nums;
            font-weight: 700;
            color: #0f172a;
        }

        .report1-empty {
            padding: 2.5rem 1rem;
            text-align: center;
            color: #64748b;
        }

        @@media (max-width: 991.98px) {
            .report1-toolbar {
                grid-template-columns: 1fr;
            }

            .report1-toolbar .btn {
                width: 100%;
            }

            .report1-summary {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}

<div class="report1-shell">
    <div class="report1-toolbar">
        <input id="report1Search" type="search" class="form-control" placeholder="Search by project, owner, plant, category, or product" />
        <select id="report1Status" class="form-select">
            <option value="">All statuses</option>
            <option value="NOT STARTED">Not Started</option>
            <option value="ONGOING">Ongoing</option>
            <option value="AT RISK">At Risk</option>
            <option value="HOLD">Hold</option>
            <option value="COMPLETED">Completed</option>
            <option value="CANCELLED">Cancelled</option>
        </select>
        <select id="report1TaskFilter" class="form-select">
            <option value="">All task health</option>
            <option value="pending">Has pending tasks</option>
            <option value="risk">Has at risk tasks</option>
            <option value="closed-delayed">Has closed delayed tasks</option>
        </select>
        <button id="report1Export" type="button" class="btn btn-success">
            <i class="bi bi-file-earmark-excel me-2"></i>Export Excel
        </button>
    </div>

    <div class="report1-summary">
        <div>
            <div class="report1-summary-title">Project Extraction</div>
            <div id="report1Summary" class="report1-summary-copy">Loading report records...</div>
        </div>
        <div id="report1Count" class="report1-count">
            <i class="bi bi-table"></i>
            <span>0 records</span>
        </div>
    </div>

    <div class="report1-table-card">
        <div class="report1-table-wrap">
            <table class="report1-table">
                <thead>
                    <tr>
                        <th>Project</th>
                        <th>Owner</th>
                        <th>Status</th>
                        <th>Plant</th>
                        <th>Category</th>
                        <th>Products</th>
                        <th>Target Start</th>
                        <th>Target Completion</th>
                        <th>Completion %</th>
                        <th>Pending Tasks</th>
                        <th>At Risk Tasks</th>
                        <th>Closed Tasks</th>
                        <th>Closed Delayed</th>
                    </tr>
                </thead>
                <tbody id="report1TableBody">
                    <tr>
                        <td colspan="13" class="report1-empty">Loading report records...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/home/report1.js"></script>
}