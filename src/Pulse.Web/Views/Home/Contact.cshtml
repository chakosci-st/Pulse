@{
    ViewBag.Title = "Contact";
    ViewBag.TitleIcon = "bi bi-envelope-fill";
    ViewBag.SubTitle = ViewBag.Message ?? "Support and escalation contacts for Pulse.";
}

@section Styles {
    <style>
        .contact-hero {
            display: grid;
            grid-template-columns: minmax(0, 1.8fr) minmax(260px, 0.9fr);
            gap: 1rem;
            padding: 1.35rem 1.4rem;
            border: 1px solid rgba(191, 219, 254, 0.9);
            border-radius: 1.25rem;
            background:
                radial-gradient(circle at top right, rgba(59, 130, 246, 0.16), transparent 34%),
                linear-gradient(135deg, #f8fbff 0%, #eef6ff 52%, #f8fafc 100%);
            box-shadow: 0 20px 48px rgba(15, 23, 42, 0.08);
            margin-bottom: 2rem;
        }
        .contact-hero__title {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: #0f172a;
            font-size: clamp(1.35rem, 2vw, 1.95rem);
            font-weight: 700;
            line-height: 1.15;
            margin-bottom: 0.5rem;
        }
        .contact-hero__title-icon {
            width: 48px;
            height: 48px;
            border-radius: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: #1d4ed8;
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            box-shadow: inset 0 0 0 1px rgba(96, 165, 250, 0.55);
        }
        .contact-hero__copy {
            max-width: 64ch;
            margin: 0.8rem 0 0;
            color: #475569;
            font-size: 0.95rem;
            line-height: 1.65;
        }
        .contact-chip-link {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.55rem 0.9rem;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.08);
            border: 1px solid rgba(148, 163, 184, 0.2);
            color: #0f172a;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 700;
            transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
        }
        .contact-chip-link:hover {
            color: #0f172a;
            border-color: rgba(96, 165, 250, 0.45);
            background: rgba(219, 234, 254, 0.92);
            transform: translateY(-1px);
        }
        @@media (max-width: 1199.98px) {
            .contact-hero {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="contact-hero">
    <div>
        <h1 class="contact-hero__title">
            <span class="contact-hero__title-icon">
                <i class="bi bi-envelope-fill"></i>
            </span>
            <span>Contact & Support</span>
        </h1>
        <p class="contact-hero__copy">
            Raise a ServiceNow ticket for incidents or access/other requests. For further support, use the contact details below.
        </p>
        <div style="margin-top:1.2rem;">
            <a class="contact-chip-link" href="https://st.service-now.com/hub?id=sc_cat_item&sys_id=579cdcba2b80a250e31df4f9dd91bf29" target="_blank" rel="noopener"><i class="bi bi-exclamation-triangle"></i>Incident Ticket</a>
            <a class="contact-chip-link" href="https://st.service-now.com/hub?id=sc_cat_item&sys_id=5fe55b463b735a10ecda582a85e45aba" target="_blank" rel="noopener"><i class="bi bi-person-plus"></i>Access/Other Request</a>
        </div>
    </div>
    <div>
        <div class="text-uppercase small text-muted mb-2">Contacts</div>
        <address class="mb-0">
            <strong>Support:</strong> <a href="mailto:ict_iog_cal_prodops@list.st.com">ict_iog_cal_prodops@list.st.com</a><br />
        </address>
    </div>
</div>