<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=301880
  -->
<configuration>
  <configSections>
    <section name="stClientConfig" type="DotNetPFClient.Configuration.WebConfiguration,DotNetPFClient" />
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net" />
  </configSections>
  <stClientConfig stLoginUrl="https://ti-intrasso.st.com" stLoginUrlPort="9031" stLogoutUrl="https://ti-intrasso.st.com:9031/idp/startSLO.ping?TargetResource=" stAppLoginUrl="http://localhost:58096/auth/login" stAdapterClientName="pulsedev" stAdapterScope="openid" stSecondaryHttpsPort="8443" stFallbackLoginEDLdapProviderURL="ldap.mua.st.com:389" stFallbackLoginSearchBase="ou=people,dc=st,dc=com" stFallbackLoginSearchAttribute="uid" stFallbackLoginContact="mailto:ictservicedesk@st.com" stAppCertPath="" stAppCertPass="" />

  <!-- Log4net Logging Setup -->
  <log4net>
    <root>
      <level value="DEBUG" />
      <appender-ref ref="RollingFileAppender" />
      <appender-ref ref="aiAppender" />
    </root>
    <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <!-- change the below log path as per need. By default, path is in app main location-->
      <file value="./logs/PULSE.log" />
      <appendToFile value="true" />
      <rollingStyle value="Composite" />
      <datePattern value="'.'yyyy_MM_dd" />
      <maxSizeRollBackups value="3" />
      <maximumFileSize value="1MB" />
      <staticLogFileName value="true" />
      <layout type="log4net.Layout.PatternLayout">
        <param name="ConversionPattern" value="%date{yyyy-MM-dd::HH:mm:ss} %-5level %logger [%thread] == %message %exception%newline" />
      </layout>
    </appender>
    <appender name="aiAppender" type="Microsoft.ApplicationInsights.Log4NetAppender.ApplicationInsightsAppender, Microsoft.ApplicationInsights.Log4NetAppender">
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%message%newline" />
      </layout>
    </appender>
  </log4net>
  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />

    <add key="defaultconnection" value="PulseConnection" />

    <add key="smtp:ClientHost" value="smtpapp1.amk.st.com" />
    <add key="smtp:ClientPort" value="25" />
    <add key="smtp:ClientMailFromAddress" value="PulseAutoMailer@st.com" />
    <add key="smtp:ClientMailFromDisplay" value="Pulse Auto-Mailer" />


    <add key="ad:LDAPConnection" value="LDAP://CALDC02.st.com" />
    <add key="ad:LDAPConnectionParameter" value="DC=st,DC=com" />
    <add key="ad:LDAPSearchServer" value="LDAP://ldap-read.sgp.st.com:389" />
    <add key="ad:LDAPSearchParameter" value="ou=People,dc=st,dc=com" />
    <add key="ad:domain" value="st" />
    <add key="ad:domainweb" value="st.com" />
    <add key="ad:domaincontainer" value="dc=st,dc=com" />
    <add key="ad:ldapserver" value="ldap-read.sgp.st.com:389" />
    <add key="ad:ldapservercontainer" value="ou=People,dc=st,dc=com" />
    <add key="ad:adgroup-emailext" value="list.st.com" />

    <add key="Jwt:SecretKey" value="{Jwt:SecretKey}" />
    <add key="Jwt:Issuer" value="http://localhost:58096" />
    <add key="Jwt:Audience" value="http://localhost:51675" />

    <add key="web:rootpath" value="http://localhost:58096" />
    <add key="api:rootpath" value="http://localhost:51675" />
    <!-- use only if not the root application when deployed, else leave blank -->
    <add key="app:rootpath" value="" /> 
    <add key="websso:logoutUrl" value="https://intrasso.st.com/idp/startSLO.ping" />

    <add key="attachments:virtualFolder" value="~/files" />
    <add key="attachments:allowedExtensions" value=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.csv,.jpg,.jpeg,.png,.gif,.zip,.7z" />
    <add key="attachments:maxFileSizeMB" value="25" />
    <add key="profilePhoto:virtualFolder" value="~/files/UserProfile" />
    <add key="profilePhoto:allowedExtensions" value=".jpg,.jpeg,.png,.gif,.bmp,.webp" />
    <add key="profilePhoto:maxFileSizeMB" value="5" />
    <add key="defaultconnection" value="PulseConnection" />
    <add key="TicketRequestURL" value="https://st.service-now.com/hub?id=my_requests" />
  </appSettings>
  <connectionStrings>
    <add name="PulseConnection" connectionString="DATA SOURCE={DATA SOURCE};PASSWORD={PASSWORD};PERSIST SECURITY INFO=True;USER ID={USER ID}; Connection Timeout=30;Min Pool Size=10;Max Pool Size=150;Incr Pool Size=5;Decr Pool Size=2; Pooling=true;  " providerName="Oracle.ManagedDataAccess.Client" />
  </connectionStrings>
  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <sessionState mode="InProc" cookieless="UseCookies" timeout="20" />
    <httpRuntime targetFramework="4.7.2" />
    <authentication mode="Forms">
      <!--<forms name=".ADAuthCookie" loginUrl="~/Account/Login" timeout="2880" slidingExpiration="true" protection="All" />-->
      <forms name="stAuthClient" loginUrl="~/pages/STAuthClient.aspx" defaultUrl="/" timeout="90" cookieless="UseCookies" slidingExpiration="true" path="/" />
    </authentication>
    <authorization>
      <deny users="?" />
    </authorization>
    <customErrors mode="On" defaultRedirect="~/Error/General">
      <error statusCode="403" redirect="~/Error/Forbidden" />
      <error statusCode="400" redirect="~/Error/BadRequest" />
      <error statusCode="401" redirect="~/Error/AccessDenied" />
      <error statusCode="404" redirect="~/Error/NotFound" />
      <error statusCode="500" redirect="~/Error/ServerError" />
      <error statusCode="503" redirect="~/Error/ServiceUnavailable" />

    </customErrors>
  </system.web>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Antlr3.Runtime" publicKeyToken="eb42632606e9261f" />
        <bindingRedirect oldVersion="0.0.0.0-3.5.0.2" newVersion="3.5.0.2" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Optimization" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-1.1.0.0" newVersion="1.1.0.0" />
