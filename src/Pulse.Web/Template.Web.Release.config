<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">

  <stClientConfig
    stLoginUrl="https://intrasso.st.com"
    stLoginUrlPort=""
    stLogoutUrl="https://intrasso.st.com:9031/idp/startSLO.ping?TargetResource="
    stAppLoginUrl="https://pulse.cal.st.com:44344/auth/login"
    stAdapterClientName="pulse"
    stAdapterScope="openid"
    stSecondaryHttpsPort="8443"
    stFallbackLoginEDLdapProviderURL="ldap-read.sgp.st.com:389,ldap.mua.st.com:389"
    stFallbackLoginSearchBase="ou=people,dc=st,dc=com"
    stFallbackLoginSearchAttribute="uid"
    stFallbackLoginContact="mailto:ictservicedesk@st.com"
    stAppCertPath="D:\Certificates\pulse\pulse.cal.st.com.pfx"
    stAppCertPass="pulsepr0j.PRD"
    xdt:Transform="SetAttributes(stLoginUrl,stLoginUrlPort,stLogoutUrl,stAppLoginUrl,stAdapterClientName,stAdapterScope,stSecondaryHttpsPort,stFallbackLoginEDLdapProviderURL,stFallbackLoginSearchBase,stFallbackLoginSearchAttribute,stFallbackLoginContact,stAppCertPath,stAppCertPass)" />

  <appSettings>
    <add key="cookie:Name" value="access_token" xdt:Transform="Insert" />
    <add key="cookie:HttpOnly" value="true" xdt:Transform="Insert" />
    <add key="cookie:Secure" value="true" xdt:Transform="Insert" />

    <add key="Jwt:Issuer" value="https://pulse.cal.st.com:44344"
         xdt:Locator="Match(key)" xdt:Transform="SetAttributes(value)" />
    <add key="Jwt:Audience" value="https://pulse.api.cal.st.com"
         xdt:Locator="Match(key)" xdt:Transform="SetAttributes(value)" />
    <add key="api:rootpath" value="https://pulse.api.cal.st.com"
         xdt:Locator="Match(key)" xdt:Transform="SetAttributes(value)" />
    <add key="web:rootpath" value="https://pulse.cal.st.com:44344"
         xdt:Locator="Match(key)" xdt:Transform="SetAttributes(value)" />

    <add key="websso:logoutUrl1" xdt:Locator="Match(key)" xdt:Transform="Remove" />
    <add key="websso:logoutUrl" value="https://intrasso.st.com/idp/startSLO.ping?TargetResource=https://pulse.cal.st.com:44344/auth/login"
         xdt:Locator="Match(key)" xdt:Transform="SetAttributes(value)" />
    <add key="websso:logoutUrl.Err" value="https://intrasso.st.com/idp/startSLO.ping?TargetResource=https%3a%2f%2fpulse.cal.st.com%3a44344%2fauth%2flogout"
         xdt:Locator="Match(key)" xdt:Transform="Insert" />
  </appSettings>

  <system.webServer>
    <rewrite xdt:Transform="Insert">
      <rules>
        <rule name="Redirect to HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}:44344/{REQUEST_URI}" appendQueryString="false" />
        </rule>
        <rule name="Redirect to 44344" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{SERVER_PORT}" pattern="^443$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}:44344/{REQUEST_URI}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>

</configuration>